@model SelfRestaurant.Gateway.Mvc.Models.CustomerForgotPasswordViewModel
@{
    ViewBag.Title = "Quên Mật Khẩu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section css{
    <style>
        .auth-wrapper {
            min-height: calc(100vh - 120px);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1.5rem 0;
        }

        .forgot-container {
            background-color: white;
            border-radius: 16px;
            box-shadow: 0 6px 20px rgba(15, 23, 42, 0.08);
            max-width: 460px;
            width: 100%;
            padding: 2rem 1.75rem;
        }

        .forgot-header {
            text-align: center;
            margin-bottom: 2rem;
        }

            .forgot-header .icon {
                font-size: 3.5rem;
                color: #d9534f;
                margin-bottom: 1rem;
            }

            .forgot-header h1 {
                font-size: 1.75rem;
                font-weight: 700;
                color: #333;
                margin: 0.5rem 0;
            }

            .forgot-header p {
                color: #6c757d;
                font-size: 0.95rem;
                line-height: 1.5;
            }

        .form-group {
            margin-bottom: 1.5rem;
        }

            .form-group label {
                font-weight: 500;
                color: #333;
                margin-bottom: 0.5rem;
                display: block;
            }

            .form-group input {
                border-radius: 8px;
                border: 2px solid #e0e0e0;
                padding: 0.75rem 1rem;
                font-size: 1rem;
                transition: border-color 0.3s ease;
            }

         .form-group input:focus {
                    border-color: #d9534f;
                    box-shadow: 0 0 0 0.2rem rgba(217, 83, 79, 0.25);
                    outline: none;
         }

        .btn-submit {
            background-color: #d9534f;
            border: none;
            padding: 0.75rem;
            font-weight: 600;
            border-radius: 8px;
            transition: background-color 0.3s ease;
            width: 100%;
            margin-bottom: 1rem;
            color: #fff;
        }

            .btn-submit:hover {
                background-color: #c9423f;
                color: #fff;
            }

            .btn-submit:disabled {
                background-color: #d3d3d3;
                cursor: not-allowed;
            }

        .back-to-login {
            text-align: center;
            color: #6c757d;
            font-size: 0.95rem;
        }

            .back-to-login a {
                color: #667eea;
                text-decoration: none;
                font-weight: 600;
            }

                .back-to-login a:hover {
                    text-decoration: underline;
                }

        .alert {
            border-radius: 8px;
            border: none;
            margin-bottom: 1.5rem;
        }

        .invalid-feedback,
        .text-danger {
            display: block;
            color: #dc3545;
            font-size: 0.875rem;
            margin-top: 0.25rem;
        }

        .info-box {
            background-color: #e7f3ff;
            border-left: 4px solid #2196F3;
            padding: 1rem;
            border-radius: 4px;
            margin-bottom: 1.5rem;
        }

            .info-box p {
                margin: 0;
                font-size: 0.9rem;
                color: #1976D2;
            }

        @@media (max-width: 576px) {
            .auth-wrapper {
                min-height: calc(100vh - 80px);
            }

            .forgot-container {
                border-radius: 0;
                box-shadow: none;
                max-width: 100%;
                padding: 1.5rem 1.25rem;
            }
        }
    </style>
}

<div class="auth-wrapper">
<div class="forgot-container">
    <div class="forgot-header">
        <div class="icon">
            <i class="fas fa-lock"></i>
        </div>
        <h1>Quên Mật Khẩu?</h1>
        <p>Đừng lo! Nhập email của bạn và chúng tôi sẽ gửi link đặt lại mật khẩu.</p>
    </div>

    <div class="info-box">
        <p>
            <i class="fas fa-info-circle me-2"></i>
            Link đặt lại mật khẩu sẽ có hiệu lực trong 30 phút.
        </p>
    </div>

    <form id="forgot-form">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label for="Email">
                <i class="fas fa-envelope me-2"></i>Email
            </label>
            <input type="email"
                   class="form-control"
                   id="email"
                   name="email"
                   value="@(Model?.UsernameOrEmailOrPhone ?? string.Empty)"
                   placeholder="Nhập email của bạn"
                   required />
            <div class="invalid-feedback" id="email-error"></div>
        </div>

        <button type="submit" class="btn btn-submit btn-danger" id="forgot-btn">
            <i class="fas fa-paper-plane me-2"></i>
            <span id="btn-text">Gửi Link Đặt Lại Mật Khẩu</span>
        </button>

        <div class="back-to-login">
            <i class="fas fa-arrow-left me-2"></i>
            <a href="@Url.Action("Login", "Customer")">Quay lại đăng nhập</a>
        </div>
    </form>

    <div id="alert-message"></div>
</div>
</div>

@section scripts{
    <script>
        document.getElementById('forgot-form').addEventListener('submit', function (e) {
            e.preventDefault();

            const email = document.getElementById('email').value.trim();
            const btnSubmit = document.getElementById('forgot-btn');
            const btnText = document.getElementById('btn-text');
            const alertDiv = document.getElementById('alert-message');

            document.getElementById('email-error').textContent = '';
            alertDiv.innerHTML = '';

            if (!email) {
                document.getElementById('email-error').textContent = 'Vui lòng nhập email';
                return;
            }

            const emailRegex = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
            if (!emailRegex.test(email)) {
                document.getElementById('email-error').textContent = 'Email không hợp lệ';
                return;
            }

            btnSubmit.disabled = true;
            btnText.innerHTML = 'Đang gửi...';

            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            const formData = new FormData();
            formData.append('UsernameOrEmailOrPhone', email);
            formData.append('__RequestVerificationToken', token);

            fetch('@Url.Action("ForgotPassword", "Customer")', {
                method: 'POST',
                headers: { 'X-Requested-With': 'XMLHttpRequest' },
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alertDiv.innerHTML = `
                        <div class="alert alert-success" role="alert">
                            <i class="fas fa-check-circle me-2"></i>
                            ${data.message}
                        </div>
                    `;
                    document.getElementById('email').value = '';
                } else {
                    alertDiv.innerHTML = `
                        <div class="alert alert-danger" role="alert">
                            <i class="fas fa-exclamation-circle me-2"></i>
                            ${data.message}
                        </div>
                    `;
                }

                btnSubmit.disabled = false;
                btnText.innerHTML = 'Gửi Link Đặt Lại Mật Khẩu';
            })
            .catch(() => {
                alertDiv.innerHTML = `
                    <div class="alert alert-danger" role="alert">
                        <i class="fas fa-exclamation-circle me-2"></i>
                        Có lỗi xảy ra. Vui lòng thử lại sau.
                    </div>
                `;

                btnSubmit.disabled = false;
                btnText.innerHTML = 'Gửi Link Đặt Lại Mật Khẩu';
            });
        });
    </script>
}
