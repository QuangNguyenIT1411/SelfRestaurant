@{
    ViewBag.Title = "Đăng Ký Tài Khoản";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section css{
    <style>
        .auth-wrapper {
            min-height: calc(100vh - 120px);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1.5rem 0;
        }

        .register-container {
            background-color: #ffffff;
            border-radius: 16px;
            box-shadow: 0 6px 20px rgba(15, 23, 42, 0.08);
            max-width: 520px;
            width: 100%;
            padding: 2rem 1.75rem;
            margin: 0 1rem;
        }

        .register-header {
            text-align: center;
            margin-bottom: 2rem;
        }

            .register-header .logo {
                font-size: 3rem;
                color: #d9534f;
                margin-bottom: 0.5rem;
            }

            .register-header h1 {
                font-size: 1.75rem;
                font-weight: 700;
                color: #333;
                margin: 0.5rem 0;
            }

            .register-header p {
                color: #6c757d;
                font-size: 0.95rem;
            }

        .form-group {
            margin-bottom: 1rem;
        }

            .form-group label {
                font-weight: 500;
                color: #333;
                margin-bottom: 0.5rem;
                display: block;
            }

            .form-group input, .form-group select {
                border-radius: 8px;
                border: 2px solid #e0e0e0;
                padding: 0.75rem 1rem;
                font-size: 1rem;
                transition: border-color 0.3s ease;
            }

                .form-group input:focus, .form-group select:focus {
                    border-color: #d9534f;
                    box-shadow: 0 0 0 0.2rem rgba(217, 83, 79, 0.25);
                    outline: none;
                }

        .btn-register {
            background-color: #d9534f;
            border: none;
            padding: 0.75rem;
            font-weight: 600;
            border-radius: 8px;
            transition: background-color 0.3s ease;
            width: 100%;
            margin-top: 1.5rem;
        }

            .btn-register:hover {
                background-color: #c9423f;
            }

        .login-link {
            text-align: center;
            color: #6c757d;
            font-size: 0.95rem;
            margin-top: 1rem;
        }

            .login-link a {
                color: #d9534f;
                text-decoration: none;
                font-weight: 600;
            }

        .invalid-feedback {
            display: block;
            color: #dc3545;
            font-size: 0.875rem;
            margin-top: 0.25rem;
        }

        .row {
            margin-left: -0.5rem;
            margin-right: -0.5rem;
        }

        .col-md-6 {
            padding-left: 0.5rem;
            padding-right: 0.5rem;
        }

        @@media (max-width: 576px) {
            .auth-wrapper {
                min-height: calc(100vh - 80px);
            }

            .register-container {
                border-radius: 0;
                box-shadow: none;
                max-width: 100%;
                padding: 1.5rem 1.25rem;
                margin: 0;
            }
        }
    </style>
}

<div class="auth-wrapper">
<div class="register-container">
    <div class="register-header">
        <div class="logo">
            <i class="fas fa-utensils"></i>
        </div>
        <h1>Self Restaurant</h1>
        <p>Tạo tài khoản mới</p>
    </div>

    <form id="register-form">
        <div style="display:none;">@Html.AntiForgeryToken()</div>
        <div class="row">
            <div class="col-md-6">
                <div class="form-group">
                    <label for="name">
                        <i class="fas fa-user me-2"></i>Họ Tên
                    </label>
                    <input type="text"
                           class="form-control"
                           id="name"
                           name="name"
                           placeholder="Nhập họ tên"
                           required>
                    <div class="invalid-feedback" id="name-error"></div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label for="phoneNumber">
                        <i class="fas fa-phone me-2"></i>Số Điện Thoại
                    </label>
                    <input type="tel"
                           class="form-control"
                           id="phoneNumber"
                           name="phoneNumber"
                           placeholder="Nhập số điện thoại"
                           required>
                    <div class="invalid-feedback" id="phoneNumber-error"></div>
                </div>
            </div>
        </div>

        <div class="form-group">
            <label for="email">
                <i class="fas fa-envelope me-2"></i>Email
            </label>
            <input type="email"
                   class="form-control"
                   id="email"
                   name="email"
                   placeholder="Nhập email"
                   required>
            <div class="invalid-feedback" id="email-error"></div>
        </div>

        <div class="form-group">
            <label for="username">
                <i class="fas fa-user-tag me-2"></i>Tên Đăng Nhập
            </label>
            <input type="text"
                   class="form-control"
                   id="username"
                   name="username"
                   placeholder="Nhập tên đăng nhập"
                   required>
            <div class="invalid-feedback" id="username-error"></div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="form-group">
                    <label for="password">
                        <i class="fas fa-lock me-2"></i>Mật Khẩu
                    </label>
                    <input type="password"
                           class="form-control"
                           id="password"
                           name="password"
                           placeholder="Nhập mật khẩu"
                           required>
                    <div class="invalid-feedback" id="password-error"></div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label for="confirmPassword">
                        <i class="fas fa-check-circle me-2"></i>Xác Nhận Mật Khẩu
                    </label>
                    <input type="password"
                           class="form-control"
                           id="confirmPassword"
                           name="confirmPassword"
                           placeholder="Xác nhận mật khẩu"
                           required>
                    <div class="invalid-feedback" id="confirmPassword-error"></div>
                </div>
            </div>
        </div>

        <button type="submit" class="btn btn-register btn-danger">
            <span id="btn-text"><i class="fas fa-user-plus me-2"></i>Đăng Ký</span>
        </button>

        <div class="login-link">
            Đã có tài khoản? <a href="@Url.Action("Login", "Customer")">Đăng nhập</a>
        </div>
    </form>

    <div id="alert-message"></div>
</div>
</div>

@{
    var registerUrl = Url.Action("Register", "Customer");
}

@section scripts{
    <script>
        var registerUrl = '@Html.Raw(registerUrl)';

        function isValidEmail(email) {
            var atPos = email.indexOf(String.fromCharCode(64));
            return email && atPos > 0 && atPos < email.length - 1;
        }

        document.getElementById('register-form').addEventListener('submit', function (e) {
            e.preventDefault();

            const name = document.getElementById('name').value.trim();
            const phoneNumber = document.getElementById('phoneNumber').value.trim();
            const email = document.getElementById('email').value.trim();
            const username = document.getElementById('username').value.trim();
            const password = document.getElementById('password').value.trim();
            const confirmPassword = document.getElementById('confirmPassword').value.trim();
            const btnSubmit = document.querySelector('button[type="submit"]');
            const alertDiv = document.getElementById('alert-message');

            document.querySelectorAll('.invalid-feedback').forEach(el => el.textContent = '');
            alertDiv.innerHTML = '';

            let isValid = true;
            if (!name) {
                document.getElementById('name-error').textContent = 'Vui lòng nhập họ tên';
                isValid = false;
            }
            if (!phoneNumber) {
                document.getElementById('phoneNumber-error').textContent = 'Vui lòng nhập số điện thoại';
                isValid = false;
            }
            if (!isValidEmail(email)) {
                document.getElementById('email-error').textContent = 'Vui lòng nhập email hợp lệ';
                isValid = false;
            }
            if (!username) {
                document.getElementById('username-error').textContent = 'Vui lòng nhập tên đăng nhập';
                isValid = false;
            }
            if (!password || password.length < 6) {
                document.getElementById('password-error').textContent = 'Mật khẩu phải có ít nhất 6 ký tự';
                isValid = false;
            }
            if (password !== confirmPassword) {
                document.getElementById('confirmPassword-error').textContent = 'Mật khẩu xác nhận không trùng khớp';
                isValid = false;
            }

            if (!isValid) return;

            btnSubmit.disabled = true;
            document.getElementById('btn-text').innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Đang đăng ký...';

            const formData = new FormData();
            formData.append('name', name);
            formData.append('phoneNumber', phoneNumber);
            formData.append('email', email);
            formData.append('username', username);
            formData.append('password', password);
            formData.append('confirmPassword', confirmPassword);
            formData.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value || '');

            fetch(registerUrl, {
                method: 'POST',
                headers: { 'X-Requested-With': 'XMLHttpRequest' },
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alertDiv.innerHTML = '<div class="alert alert-success mt-3" role="alert"><i class="fas fa-check-circle me-2"></i>' + data.message + '</div>';
                    setTimeout(() => {
                        window.location.href = data.redirectUrl || '@Url.Action("Login", "Customer")';
                    }, 2000);
                } else {
                    alertDiv.innerHTML = '<div class="alert alert-danger mt-3" role="alert"><i class="fas fa-exclamation-circle me-2"></i>' + data.message + '</div>';
                    btnSubmit.disabled = false;
                    document.getElementById('btn-text').innerHTML = '<i class="fas fa-user-plus me-2"></i>Đăng Ký';
                }
            })
            .catch(() => {
                alertDiv.innerHTML = '<div class="alert alert-danger mt-3" role="alert"><i class="fas fa-exclamation-circle me-2"></i>Có lỗi xảy ra. Vui lòng thử lại.</div>';
                btnSubmit.disabled = false;
                document.getElementById('btn-text').innerHTML = '<i class="fas fa-user-plus me-2"></i>Đăng Ký';
            });
        });
    </script>
}
