@using Microsoft.AspNetCore.Http
@using SelfRestaurant.Gateway.Mvc.Infrastructure
@{
    ViewBag.Title = "Về Chúng Tôi";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var isCustomerLoggedIn = Context.Session.GetInt32(SessionKeys.CustomerId) is not null;
    var customerName = Context.Session.GetString(SessionKeys.CustomerName) ?? "";
}

@section css{
<style>
    body { font-family: "Inter", sans-serif; background: #f8f9fa; }
    .navbar-brand { font-weight: 700; font-size: 1.75rem; color: #d9534f !important; }
    .hero { background: linear-gradient(135deg,#1f2937,#111827); color:#fff; padding: 4rem 0; }
</style>
}

<nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm sticky-top">
    <div class="container">
        <a class="navbar-brand" href="@Url.Action("Index", "Home")">Self Restaurant</a>
        <div class="collapse navbar-collapse show">
            <ul class="navbar-nav ms-auto align-items-center gap-2">
                <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "Home")">Trang Chủ</a></li>
                <li class="nav-item"><a class="nav-link active" href="@Url.Action("About", "Home")">Về Chúng Tôi</a></li>
                <li class="nav-item"><a class="nav-link" href="@Url.Action("Contact", "Home")">Liên Hệ</a></li>
                @if (isCustomerLoggedIn)
                {
                    <li class="nav-item"><a class="nav-link" href="@Url.Action("Dashboard", "Customer")">@customerName</a></li>
                    <li class="nav-item">
                        <form method="post" action="@Url.Action("Logout", "Customer")">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-sm btn-outline-danger" type="submit">Đăng Xuất</button>
                        </form>
                    </li>
                }
                else
                {
                    <li class="nav-item"><a class="btn btn-sm btn-outline-secondary" href="@Url.Action("Login", "Customer", new { mode = "login" })">Đăng Nhập</a></li>
                    <li class="nav-item"><a class="btn btn-sm btn-danger" href="@Url.Action("Login", "Customer", new { mode = "register" })">Đăng Ký</a></li>
                }
            </ul>
        </div>
    </div>
</nav>

<header class="hero">
    <div class="container">
        <h1 class="display-6 fw-bold">Về Self Restaurant</h1>
        <p class="mb-0">Mô hình nhà hàng tự phục vụ, đặt món nhanh, bếp xử lý theo thời gian thực.</p>
    </div>
</header>

<div class="container py-4">
    <div class="bg-white rounded shadow-sm p-4">
        <h3>Sứ mệnh</h3>
        <p>Tăng tốc trải nghiệm gọi món và minh bạch trạng thái đơn cho khách hàng.</p>
        <h3>Điểm khác biệt</h3>
        <ul>
            <li>Chọn chi nhánh, chọn bàn, đặt món trực tiếp.</li>
            <li>Theo dõi trạng thái chế biến theo thời gian thực.</li>
            <li>Tách vai trò rõ ràng giữa khách hàng, bếp, thu ngân, quản lý.</li>
        </ul>
    </div>
</div>
