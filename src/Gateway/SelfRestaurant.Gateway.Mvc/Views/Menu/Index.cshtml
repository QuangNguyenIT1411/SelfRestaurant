                                 class="dish-image"
                                 alt="${dish.Name}"
                                 onerror="fallbackDishImage(this)">
                            ${dish.isVegetarian ? `
                                <span class="badge-vegetarian">
                                    <i class="bi bi-leaf"></i> Chay
                                </span>` : ``}
                            <span class="badge-top-seller">
                                <i class="bi bi-star-fill"></i> Bán chạy
                            </span>
                        </div>
                        <div class="card-body">
                            <h5 class="card-title">${dish.Name}</h5>
                            <p class="card-text text-muted small">${dish.Description || ''}</p>
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="price">${parseInt(dish.Price).toLocaleString("vi-VN")}đ</div>
                                    <small class="text-muted">${dish.Unit}</small>
                                </div>
                                <button class="btn-add" onclick="addToCart(${dish.DishID}, this)">
                                    <i class="bi bi-plus-lg me-1"></i>Thêm
                                </button>
