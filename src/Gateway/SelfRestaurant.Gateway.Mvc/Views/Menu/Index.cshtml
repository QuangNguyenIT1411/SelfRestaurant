        // Increase/Decrease Quantity
        function increaseQuantity(btn) {
            const display = btn.parentElement.querySelector(".quantity-display");
            let qty = parseInt(display.textContent);
            display.textContent = qty + 1;
        }

        function decreaseQuantity(btn) {
            const display = btn.parentElement.querySelector(".quantity-display");
            let qty = parseInt(display.textContent);
            if (qty > 1) {
                display.textContent = qty - 1;
            }
        }

        // Add to Cart
        function addToCart(dishId, btnElement) {
            const dish = dishes.find(d => d.DishID === dishId);
            if (!dish) return;

            // Mặc định số lượng = 1 (dùng cho Món bán chạy không có bộ điều khiển số lượng)
            let quantity = 1;
            const container = btnElement.closest(".d-flex");
            if (container) {
                const quantityDisplay = container.querySelector(".quantity-display");
                if (quantityDisplay) {
                    const parsed = parseInt(quantityDisplay.textContent);
                    if (!isNaN(parsed) && parsed > 0) {
                        quantity = parsed;
                    }
                    // Reset lại về 1 cho lần tiếp theo
                    quantityDisplay.textContent = "1";
                }
            }

            const existing = pendingItems.find(item => item.DishID === dishId);

            if (existing) {
                existing.quantity += quantity;
            } else {
                pendingItems.push({
                    ...dish,
                    quantity: quantity,
                    status: "pending",
                    orderedAt: new Date()
                });
            }

            renderCart();
            updateSendButton();
            showToast("success", `Đã thêm ${quantity} ${dish.Unit} ${dish.Name} vào giỏ hàng`);
        }

        // Show Send Kitchen Confirmation Modal
        function showSendKitchenConfirm() {
            if (pendingItems.length === 0) {
                showToast("info", "Không có món nào để gửi");
                return;
            }

            // Nếu khách hàng chưa đăng nhập thì chuyển tới trang đăng nhập
            if (!isCustomerLoggedIn) {
                showToast("warning", "Vui lòng đăng nhập tài khoản khách hàng để đặt món.");
                window.location.href = customerLoginUrl;
                return;
            }

            // Render danh sách xác nhận
            const confirmList = document.getElementById("confirmItemsList");
            confirmList.innerHTML = pendingItems.map(item => `
                <div class="confirm-item">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="flex-grow-1">
                            <strong>${item.Name}</strong>
                            <div class="text-muted small">
                                ${parseInt(item.Price).toLocaleString("vi-VN")}đ × ${item.quantity}
                                ${item.note ? `<br><em style="color: #dc3545;">Ghi chú: ${item.note}</em>` : ""}
                            </div>
                        </div>
                        <div class="fw-bold" style="color: var(--primary-color)">
                            x${item.quantity}
                        </div>
                    </div>
                </div>
            `).join("");

            // Show modal
            const modal = new bootstrap.Modal(document.getElementById("confirmSendKitchenModal"));
            modal.show();
        }

                // Confirm Send to Kitchen - GỬI LÊN SERVER
        function confirmSendKitchen() {
            if (pendingItems.length === 0) {
                showToast("info", "Không có món nào để gửi");
                return;
            }

            // Nếu khách hàng chưa đăng nhập thì chuyển tới trang đăng nhập
            if (!isCustomerLoggedIn) {
                showToast("warning", "Vui lòng đăng nhập tài khoản khách hàng để đặt món.");
                window.location.href = customerLoginUrl;
                return;
            }

            const btnConfirmSend = document.getElementById("btnConfirmSend");
            const originalText = btnConfirmSend.innerHTML;

            // Disable button
            btnConfirmSend.disabled = true;
            btnConfirmSend.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Đang gửi...';

            // Chuẩn bị dữ liệu gửi lên server
            const itemsToSend = pendingItems.map(item => ({
                DishID: item.DishID,
                Quantity: item.quantity,
                Note: item.note || ""
            }));

            console.log("Sending items:", itemsToSend);
            console.log("TableID:", tableID, "BranchId:", branchId);

            // Lấy CSRF Token từ form
            const tokenElement = document.querySelector('input[name="__RequestVerificationToken"]');
            if (!tokenElement) {
                showToast("error", "Lỗi bảo mật: Không tìm thấy CSRF token");
                btnConfirmSend.disabled = false;
                btnConfirmSend.innerHTML = originalText;
                return;
            }

            const tokenValue = tokenElement.value;

            // Gửi POST request tới server bằng FormData
            const formData = new FormData();
            formData.append('tableId', tableID);
            formData.append('branchId', branchId);
            formData.append('items', JSON.stringify(itemsToSend));
            formData.append('__RequestVerificationToken', tokenValue);

            fetch('@Url.Action("SendOrderToKitchen", "Menu")', {
                method: 'POST',
                body: formData,
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(response => {
                console.log("Response status:", response.status);
                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }
                return response.json();
            })
            .then(data => {
                console.log("Response data:", data);

                // Server yêu cầu đăng nhập
                if (data.requiresLogin && data.loginUrl) {
                    showToast("warning", "Phiên làm việc đã hết hạn, vui lòng đăng nhập lại.");
                    window.location.href = data.loginUrl;
                    return;
                }

                if (data.success) {
                    // Chuyển từ pending sang cart (đã gửi)
                    pendingItems.forEach(item => {
                        const existing = cart.find(c => c.DishID === item.DishID && c.status === "preparing");
                        if (existing) {
                            existing.quantity += item.quantity;
                        } else {
                            cart.push({
                                ...item,
                                status: "preparing",
                                orderedAt: new Date()
                            });
                        }
                    });

                    showToast("success", data.message || `Đã gửi yêu cầu ${pendingItems.length} món cho bếp`);
                    pendingItems = [];
                    renderCart();
                    updateSendButton();

                    // Lưu orderId để theo dõi trạng thái món
                    if (data.orderID) {
                        currentOrderId = data.orderID;
                        startOrderStatusWatcher();
                    }

                    // Đóng modal
                    const modal = bootstrap.Modal.getInstance(document.getElementById("confirmSendKitchenModal"));
                    if (modal) {
                        modal.hide();
                    }
                } else {
                    showToast("error", data.message || "Có lỗi xảy ra khi gửi đơn");
                    console.error("Server error:", data);
                    btnConfirmSend.disabled = false;
                    btnConfirmSend.innerHTML = originalText;
                }
            })
            .catch(error => {
                console.error('Fetch error:', error);
                showToast("error", "Có lỗi xảy ra: " + error.message);
                btnConfirmSend.disabled = false;
                btnConfirmSend.innerHTML = originalText;
            });
        }

        // Xem chi tiết món ăn
        function showDishDetail(dishId) {
            const dish = dishes.find(d => d.DishID === dishId);
            if (!dish) return;

            const ingredientLines = (dishIngredients || []).filter(x => x.dishId === dishId);
            const fallbackIngredients = Array.isArray(dish.Ingredients)
                ? dish.Ingredients.map(x => ({
                    name: x.Name ?? x.name ?? "",
                    quantity: Number(x.Quantity ?? x.quantity ?? 0),
                    unit: x.Unit ?? x.unit ?? ""
                }))
                : [];
            const ing = ingredientLines.length > 0 ? ingredientLines : fallbackIngredients;

            const detailHtml = `
                <div class="modal fade" id="dishDetailModal" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">
                                    ${dish.Name}
                                    ${dish.isVegetarian ? '<span class="badge bg-success ms-2">Chay</span>' : ''}
                                </h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                <div class="mb-3 text-center">
                                    <img src="${resolveDishImage(dish)}"
                                         class="img-fluid rounded"
                                         style="max-height:220px;object-fit:cover;"
                                         onerror="fallbackDishImage(this)" />
                                </div>
                                <p class="text-muted">${dish.Description || 'Món ăn đang cập nhật mô tả.'}</p>
                                <hr />
                                <h6 class="fw-bold mb-2">Thành phần</h6>
                                ${ing.length === 0
                                    ? '<div class="text-muted small">Chưa khai báo thành phần cho món này.</div>'
                                    : `<ul class="small mb-0">${
                                        ing.map(x =>
                                            `<li>${x.name}: <strong>${x.quantity.toLocaleString('vi-VN')} ${x.unit}</strong></li>`
                                        ).join('')
                                      }</ul>`
                                }
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                                <button type="button" class="btn btn-primary" data-bs-dismiss="modal" onclick="quickAddDish(${dish.DishID})">
                                    <i class="bi bi-plus-lg me-1"></i>Thêm vào giỏ
                                </button>
                            </div>
                        </div>
                    </div>
                </div>`;

            const existing = document.getElementById("dishDetailModal");
            if (existing) {
                existing.parentElement.removeChild(existing);
            }

            const wrapper = document.createElement("div");
            wrapper.innerHTML = detailHtml;
            document.body.appendChild(wrapper.firstElementChild);

            const modalEl = document.getElementById("dishDetailModal");
            const modal = new bootstrap.Modal(modalEl);
            modal.show();
        }

        function quickAddDish(dishId) {
            const dummyBtn = document.createElement("button");
            dummyBtn.closest = () => null;
            addToCart(dishId, dummyBtn);
        }

        // Show Toast
        function showToast(type, message) {
            const bgClass = type === "success" ? "success" : type === "error" ? "danger" : "info";
            const toastHTML = `
                <div class="toast align-items-center text-white bg-${bgClass} border-0" role="alert">
                    <div class="d-flex">
                        <div class="toast-body">
                            <i class="bi bi-check-circle me-2"></i>${message}
                        </div>
                        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                    </div>
                </div>
            `;

            const container = document.createElement("div");
            container.style.position = "fixed";
            container.style.top = "6rem";
            container.style.left = "50%";
            container.style.transform = "translateX(-50%)";
            container.style.zIndex = "9999";
            container.innerHTML = toastHTML;
            document.body.appendChild(container);

            const toastElement = container.querySelector(".toast");
            const toast = new bootstrap.Toast(toastElement);
            toast.show();

            toastElement.addEventListener("hidden.bs.toast", () => {
                container.remove();
            });
        }

        // Update Quantity
        function updateQuantity(dishId, delta) {
            let item = pendingItems.find(i => i.DishID === dishId);
            let isPending = true;

            if (!item) {
                item = cart.find(i => i.DishID === dishId);
                isPending = false;
            }

            if (item) {
                item.quantity += delta;
                if (item.quantity <= 0) {
                    if (isPending) {
                        pendingItems = pendingItems.filter(i => i.DishID !== dishId);
                    } else {
                        cart = cart.filter(i => i.DishID !== dishId);
                    }
                }
                renderCart();
                updateSendButton();
            }
        }

        // Remove from Cart
        function removeFromCart(dishId) {
            const pendingItem = pendingItems.find(i => i.DishID === dishId);
            if (pendingItem) {
                pendingItems = pendingItems.filter(i => i.DishID !== dishId);
                showToast("info", `Đã xóa ${pendingItem.Name} khỏi giỏ hàng`);
            } else {
                const item = cart.find(i => i.DishID === dishId);
                if (item) {
                    cart = cart.filter(i => i.DishID !== dishId);
                    showToast("info", `Đã xóa ${item.Name} khỏi giỏ hàng`);
                }
            }
            renderCart();
            updateSendButton();
        }

        // Render Cart
        function renderCart() {
            const cartItems = document.getElementById("cartItems");
            const cartBadge = document.getElementById("cartBadge");
            const cartSummary = document.getElementById("cartSummary");
            const totalAmount = document.getElementById("totalAmount");

            const allItems = [...pendingItems, ...cart];
            const totalItems = allItems.reduce((sum, item) => sum + item.quantity, 0);
            const total = allItems.reduce((sum, item) => sum + item.Price * item.quantity, 0);

            cartBadge.textContent = totalItems;

            if (allItems.length === 0) {
                cartItems.innerHTML = `
                    <div class="empty-cart">
                        <i class="bi bi-cart3"></i>
                        <p class="mb-1">Giỏ hàng trống</p>
                        <small>Hãy chọn món ăn yêu thích</small>
                    </div>
                `;
                cartSummary.classList.add("d-none");
            } else {
                let itemsHTML = "";

                if (pendingItems.length > 0) {
                    itemsHTML += '<div class="mb-2"><small class="text-muted fw-bold"><i class="bi bi-clock-history me-1"></i>Chưa gửi bếp</small></div>';
                    itemsHTML += pendingItems.map(item => `
                        <div class="cart-item" style="background: #fff3cd;">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div class="flex-grow-1">
                                    <div class="fw-bold">${item.Name}</div>
                                    <small class="text-muted">${parseInt(item.Price).toLocaleString("vi-VN")}đ × ${item.quantity}</small>
                                    <div class="mt-1"><span class="badge bg-secondary"><i class="bi bi-hourglass me-1"></i>Chờ gửi</span></div>
                                </div>
                                <button class="btn btn-link text-danger p-0" onclick="removeFromCart(${item.DishID})"><i class="bi bi-trash"></i></button>
                            </div>
                            <input type="text" class="form-control form-control-sm note-input mb-2"
                                   placeholder="Ghi chú (vd: ít cay, không hành...)"
                                   value="${item.note || ''}"
                                   onchange="updateNote(${item.DishID}, this.value, 'pending')">
                            <div class="d-flex justify-content-between align-items-center">
                                <div class="quantity-control">
                                    <button onclick="updateQuantity(${item.DishID}, -1)"><i class="bi bi-dash"></i></button>
                                    <span class="px-3 fw-bold">${item.quantity}</span>
                                    <button onclick="updateQuantity(${item.DishID}, 1)"><i class="bi bi-plus"></i></button>
                                </div>
                                <div class="fw-bold" style="color: var(--primary-color)">${(item.Price * item.quantity).toLocaleString("vi-VN")}đ</div>
                            </div>
                        </div>
                    `).join("");
                }

                if (cart.length > 0) {
                    if (pendingItems.length > 0) itemsHTML += '<hr><div class="mb-2"><small class="text-muted fw-bold"><i class="bi bi-fire me-1"></i>Đang xử lý</small></div>';

                    itemsHTML += cart.map(item => `
                        <div class="cart-item ${(item.status === "ready" || item.status === "served") ? "ready" : ""}">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div class="flex-grow-1">
                                    <div class="fw-bold">
                                        ${item.Name}
                                        ${item.status === "ready"
                                            ? '<i class="bi bi-check-circle-fill text-success ms-1"></i>'
                                            : (item.status === "served" ? '<i class="bi bi-hand-thumbs-up-fill text-primary ms-1"></i>' : "")}
                                    </div>
                                    <small class="text-muted">${parseInt(item.Price).toLocaleString("vi-VN")}đ × ${item.quantity}</small>
                                    ${item.note ? `<span class="item-note-display"><i class="bi bi-pencil-fill me-1" style="font-size: 10px;"></i>${item.note}</span>` : ""}
                                    <div class="mt-1">
                                        ${item.status === "preparing"
                                            ? '<span class="badge bg-warning text-dark"><i class="bi bi-clock me-1"></i>Đang chuẩn bị</span>'
                                            : (item.status === "served"
                                                ? '<span class="badge bg-primary"><i class="bi bi-hand-thumbs-up me-1"></i>Đã nhận món</span>'
                                                : '<span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Sẵn sàng</span>')}
                                    </div>
                                </div>
                                <button class="btn btn-link text-danger p-0" onclick="removeFromCart(${item.DishID})"><i class="bi bi-trash"></i></button>
                            </div>
                            <div class="d-flex justify-content-end align-items-center">
                                <div class="fw-bold" style="color: var(--primary-color)">${(item.Price * item.quantity).toLocaleString("vi-VN")}đ</div>
                            </div>
                        </div>
                    `).join("");
                }

                cartItems.innerHTML = itemsHTML;
                totalAmount.textContent = total.toLocaleString("vi-VN") + "đ";
                cartSummary.classList.remove("d-none");
            }

            saveCartToStorage();
        }

        // Update Send Button
        function updateSendButton() {
            const btnSend = document.getElementById("btnSendKitchen");
            if (pendingItems.length > 0) {
                btnSend.disabled = false;
                btnSend.innerHTML = `<i class="bi bi-check-circle me-2"></i>Yêu cầu ${pendingItems.length} món cho bếp`;
            } else {
                btnSend.disabled = true;
                btnSend.innerHTML = `<i class="bi bi-check-circle me-2"></i>Yêu cầu cho bếp`;
            }
        }

        // View Bill
        function viewBill() {
            const allItems = [...pendingItems, ...cart];

            if (allItems.length === 0) {
                showToast("info", "Giỏ hàng trống");
                return;
            }

            const modal = new bootstrap.Modal(document.getElementById("billModal"));
            const billItems = document.getElementById("billItems");
            const billTime = document.getElementById("billTime");
            const billTotalItems = document.getElementById("billTotalItems");
            const billSubtotal = document.getElementById("billSubtotal");
            const billTotal = document.getElementById("billTotal");
            const billPoints = document.getElementById("billPoints");

            const now = new Date();
            billTime.textContent = now.toLocaleString("vi-VN", {
                hour: "2-digit",
                minute: "2-digit",
                day: "2-digit",
                month: "2-digit",
                year: "numeric"
            });

            const totalItems = allItems.reduce((sum, item) => sum + item.quantity, 0);
            const total = allItems.reduce((sum, item) => sum + item.Price * item.quantity, 0);
            const points = Math.floor(total * 0.01);

            billItems.innerHTML = allItems.map(item => `
                <div class="bill-item">
                    <div class="d-flex justify-content-between align-items-start mb-1">
                        <div class="flex-grow-1">
                            <div class="fw-bold">${item.Name}</div>
                            <small class="text-muted">${parseInt(item.Price).toLocaleString("vi-VN")}đ × ${item.quantity} ${item.Unit}</small>
                            ${item.note ? `<div class="small fst-italic text-danger">Ghi chú: ${item.note}</div>` : ""}
                        </div>
                        <div class="text-end">
                            ${item.status === "pending"
                                ? '<span class="badge bg-secondary small mb-1">Chờ gửi</span>'
                                : (item.status === "served"
                                    ? '<span class="badge bg-primary small mb-1">Đã nhận món</span>'
                                    : '<span class="badge bg-success small mb-1">Đã đặt</span>')}
                            <div class="fw-bold" style="color: var(--primary-color)">
                                ${(item.Price * item.quantity).toLocaleString("vi-VN")}đ
                            </div>
                        </div>
                    </div>
                </div>
            `).join("");

            billTotalItems.textContent = `${totalItems} món`;
            billSubtotal.textContent = total.toLocaleString("vi-VN") + "đ";
            billTotal.textContent = total.toLocaleString("vi-VN") + "đ";
            billPoints.textContent = points;

            modal.show();
        }

        // Checkout
        function checkout() {
            if (cart.length === 0) {
                if (pendingItems.length > 0) {
                    showToast("info", "Vui lòng gửi món cho bếp trước khi thanh toán.");
                } else {
                    showToast("info", "Giỏ hàng trống. Vui lòng chọn món ăn.");
                }
                return;
            }

            const hasPreparingItems = cart.some(item => item.status === "preparing");

            if (hasPreparingItems) {
                showToast("info", "Vui lòng đợi tất cả món ăn được chuẩn bị xong trước khi thanh toán.");
                return;
            }

            const billModalEl = document.getElementById("billModal");
            const billModal = bootstrap.Modal.getInstance(billModalEl);
            if (billModal) {
                billModal.hide();
            }

            const checkoutModal = new bootstrap.Modal(document.getElementById("checkoutNotificationModal"));
            checkoutModal.show();
        }

        // ====== LƯU / LOAD GIỎ HÀNG TRONG LOCALSTORAGE ======
        function saveCartToStorage() {
            const data = {
                pendingItems: pendingItems,
                cart: cart
            };
            try {
                localStorage.setItem(cartStorageKey, JSON.stringify(data));
            } catch (e) {
                console.warn("Không thể lưu giỏ hàng:", e.message);
            }
        }

        function loadCartFromStorage() {
            try {
                const raw = localStorage.getItem(cartStorageKey);
                if (!raw) return;
                const data = JSON.parse(raw);
                pendingItems = data.pendingItems || [];
                cart = data.cart || [];
            } catch (e) {
                console.warn("Không thể đọc giỏ hàng:", e.message);
            }
        }

        // Update Note
        function updateNote(dishId, noteContent, listType) {
            let item;
            if (listType === "pending") {
                item = pendingItems.find(i => i.DishID === dishId);
            } else {
                item = cart.find(i => i.DishID === dishId);
            }

            if (item) {
                item.note = noteContent.trim();
            }
        }

        // Initialize Loyalty Info
        function initializeLoyaltyInfo() {
            const loyaltyInfo = document.getElementById("loyaltyInfo");
            const customerNameEl = document.getElementById("customerName");
            const loyaltyPointsEl = document.getElementById("loyaltyPoints");

            if (isCustomerLoggedIn && loyaltyInfo && customerNameEl && loyaltyPointsEl) {
                customerNameEl.textContent = customerName;
                loyaltyPointsEl.textContent = Number(loyaltyPoints || 0).toLocaleString("vi-VN");
                loyaltyInfo.classList.remove("d-none");
            }
        }

    </script>
}
