        // Render Dishes
        function renderDishes() {
            const grid = document.getElementById("dishesGrid");
            let filteredDishes = dishes.filter(d => d.categoryId === selectedCategory);

            const searchInput = document.getElementById("dishSearchInput");
            const search = (searchInput && searchInput.value ? searchInput.value : "").toLowerCase();

            if (showOnlyVegetarian) {
                filteredDishes = filteredDishes.filter(d => d.isVegetarian);
            }

            if (search) {
                filteredDishes = filteredDishes.filter(d =>
                    (d.Name || "").toLowerCase().indexOf(search) !== -1
                );
            }

            if (filteredDishes.length === 0) {
                grid.innerHTML = '<div class="col-12"><div class="empty-cart"><i class="bi bi-inbox"></i><p>Không có món ăn nào</p></div></div>';
                return;
            }

            grid.innerHTML = filteredDishes.map(dish => `
                <div class="col-md-6">
                    <div class="card dish-card">
                        <div class="position-relative">
                            <img src="${dish.Image || 'https://placehold.co/300x200?text=No+Image'}"
                                 class="dish-image"
                                 alt="${dish.Name}"
                                 onerror="fallbackDishImage(this)">
                            ${dish.isVegetarian ? `
                                <span class="badge-vegetarian">
                                    <i class="bi bi-leaf"></i> Chay
                                </span>` : ``}
                            ${Array.isArray(topDishIds) && topDishIds.indexOf(dish.DishID) !== -1 ? `
                                <span class="badge-top-seller">
                                    <i class="bi bi-star-fill"></i> Bán chạy
                                </span>` : ``}
                        </div>
                        <div class="card-body">
                            <h5 class="card-title">${dish.Name}</h5>
                            <p class="card-text text-muted small">${dish.Description || ''}</p>
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="price">${parseInt(dish.Price).toLocaleString("vi-VN")}đ</div>
                                    <small class="text-muted">${dish.Unit}</small>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="quantity-control">
                                        <button onclick="decreaseQuantity(this)">
                                            <i class="bi bi-dash"></i>
                                        </button>
                                        <span class="px-3 fw-bold quantity-display">1</span>
                                        <button onclick="increaseQuantity(this)">
                                            <i class="bi bi-plus"></i>
                                        </button>
                                    </div>
                                    <button class="btn-add" onclick="addToCart(${dish.DishID}, this)">
                                        <i class="bi bi-plus-lg me-1"></i>Thêm
                                    </button>
                                </div>
                            </div>
                            <button type="button"
                                    class="btn btn-link p-0 mt-2 small"
                                    onclick="showDishDetail(${dish.DishID})">
