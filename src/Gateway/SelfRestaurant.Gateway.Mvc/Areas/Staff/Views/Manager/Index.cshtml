@model SelfRestaurant.Gateway.Mvc.Areas.Staff.Models.ManagerDashboardViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Quản lý - Tổng quan";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="m-0">Quản lý - Tổng quan chi nhánh</h2>
            <div class="text-muted small">@Model.BranchName - @Model.EmployeeName (@Model.RoleName)</div>
        </div>
        <form method="post" asp-action="Logout" asp-controller="Account" asp-area="Staff">
            @Html.AntiForgeryToken()
            <button class="btn btn-outline-danger btn-sm" type="submit">Đăng xuất</button>
        </form>
    </div>

    @if (TempData["Error"] is string error)
    {
        <div class="alert alert-danger">@error</div>
    }

    <div class="row g-3 mb-3">
        <div class="col-md-3"><div class="border rounded p-3 bg-white"><div class="text-muted small">Bếp chờ xử lý</div><div class="fs-4 fw-bold">@Model.PendingKitchenCount</div></div></div>
        <div class="col-md-3"><div class="border rounded p-3 bg-white"><div class="text-muted small">Bếp đang chuẩn bị</div><div class="fs-4 fw-bold">@Model.PreparingKitchenCount</div></div></div>
        <div class="col-md-3"><div class="border rounded p-3 bg-white"><div class="text-muted small">Bếp sẵn sàng/phục vụ</div><div class="fs-4 fw-bold">@Model.ReadyKitchenCount</div></div></div>
        <div class="col-md-3"><div class="border rounded p-3 bg-white"><div class="text-muted small">Đơn chờ thanh toán</div><div class="fs-4 fw-bold">@Model.ActiveCashierOrdersCount</div></div></div>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-md-6"><div class="border rounded p-3 bg-white"><div class="text-muted small">Số bill hôm nay</div><div class="fs-4 fw-bold">@Model.TodayBillCount</div></div></div>
        <div class="col-md-6"><div class="border rounded p-3 bg-white"><div class="text-muted small">Doanh thu hôm nay</div><div class="fs-4 fw-bold text-danger">@Model.TodayRevenue.ToString("n0")</div></div></div>
    </div>

    <div class="card border-0 shadow-sm mb-3">
        <div class="card-header">Món bán chạy</div>
        <div class="card-body">
            @if (Model.TopDishes.Count == 0)
            {
                <div class="text-muted">Chưa có dữ liệu.</div>
            }
            else
            {
                <ol class="mb-0">
                    @foreach (var d in Model.TopDishes)
                    {
                        <li>@d.Name <span class="text-muted">(#@d.DishId)</span></li>
                    }
                </ol>
            }
        </div>
    </div>

    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-primary" asp-action="Index" asp-controller="Chef" asp-area="Staff">Điều phối Bếp</a>
        <a class="btn btn-primary" asp-action="Index" asp-controller="Cashier" asp-area="Staff">Điều phối Thu ngân</a>
        <a class="btn btn-outline-secondary" asp-action="Index" asp-controller="Dashboard" asp-area="Admin">Admin Dashboard</a>
        <a class="btn btn-outline-secondary" asp-action="Index" asp-controller="Categories" asp-area="Admin">Danh mục món</a>
    </div>
</div>
