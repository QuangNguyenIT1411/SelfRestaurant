@model SelfRestaurant.Gateway.Mvc.Areas.Staff.Models.ChefDashboardViewModel

<div class="kanban-board">
    <div class="kanban-column">
        <div class="kanban-header text-secondary">
            <span><i class="bi bi-hourglass-split me-2"></i>Chờ Chế Biến</span>
            <span class="badge bg-secondary rounded-pill">@Model.PendingOrdersCount</span>
        </div>
        <div id="pending-orders">
            @foreach (var order in Model.PendingOrders)
            {
                <div class="order-card priority-normal" id="order-@order.OrderID">
                    <div class="order-header">
                        <span class="table-badge">@order.TableName</span>
                        <span class="order-time"><i class="bi bi-clock me-1"></i>@order.OrderTime.ToString("HH:mm")</span>
                    </div>
                    <div class="mb-2 text-muted small">#@order.OrderCode</div>
                    <ul class="order-items">
                        @foreach (var item in order.Items)
                        {
                            <li class="order-item">
                                <div class="d-flex w-100">
                                    <span class="item-qty">@item.Quantity</span>
                                    <div class="flex-grow-1">
                                        <div class="item-name">
                                            @item.DishName
                                            <button type="button"
                                                    class="btn btn-xs btn-outline-secondary ms-1"
                                                    style="padding:0 6px;font-size:11px;border-radius:999px;"
                                                    onclick="openOrderItemIngredients(@item.ItemID)">
                                                Thành phần
                                            </button>
                                        </div>
                                        @if (!string.IsNullOrEmpty(item.Note))
                                        {
                                            <span class="item-note">Note: @item.Note</span>
                                        }
                                    </div>
                                </div>
                            </li>
                        }
                    </ul>
                    <div class="d-grid gap-2">
                        <button class="btn btn-primary btn-action" onclick="updateStatus(@order.OrderID, 'PREPARING')">
                            <i class="bi bi-play-fill me-1"></i>Bắt đầu nấu
                        </button>
                        <button class="btn btn-outline-danger btn-action" onclick="openCancelOrderModal(@order.OrderID)">
                            <i class="bi bi-x-circle me-1"></i>Hủy đơn
                        </button>
                    </div>
                </div>
            }
            @if (Model.PendingOrdersCount == 0)
            {
                <div class="text-center text-muted py-5">
                    <i class="bi bi-check2-circle fs-1 mb-2"></i>
                    <p>Không có đơn chờ</p>
                </div>
            }
        </div>
    </div>

    <div class="kanban-column">
        <div class="kanban-header text-primary">
            <span><i class="bi bi-fire me-2"></i>Đang Chế Biến</span>
            <span class="badge bg-primary rounded-pill">@Model.PreparingOrdersCount</span>
        </div>
        <div id="preparing-orders">
            @foreach (var order in Model.PreparingOrders)
            {
                <div class="order-card priority-high" id="order-@order.OrderID">
                    <div class="order-header">
                        <span class="table-badge">@order.TableName</span>
                        <span class="order-time"><i class="bi bi-clock me-1"></i>@order.OrderTime.ToString("HH:mm")</span>
                    </div>
                    <div class="mb-2 text-muted small">#@order.OrderCode</div>
                    <ul class="order-items">
                        @foreach (var item in order.Items)
                        {
                            <li class="order-item">
                                <div class="d-flex w-100">
                                    <span class="item-qty">@item.Quantity</span>
                                    <div class="flex-grow-1">
                                        <div class="item-name">
                                            @item.DishName
                                            <button type="button"
                                                    class="btn btn-xs btn-outline-secondary ms-1"
                                                    style="padding:0 6px;font-size:11px;border-radius:999px;"
                                                    onclick="openOrderItemIngredients(@item.ItemID)">
                                                Thành phần
                                            </button>
                                        </div>
                                        @if (!string.IsNullOrEmpty(item.Note))
                                        {
                                            <span class="item-note">Note: @item.Note</span>
                                        }
                                    </div>
                                </div>
                            </li>
                        }
                    </ul>
                    <div class="d-grid gap-2">
                        <button class="btn btn-success btn-action" onclick="updateStatus(@order.OrderID, 'READY')">
                            <i class="bi bi-check-lg me-1"></i>Hoàn thành
                        </button>
                        <button class="btn btn-outline-danger btn-action" onclick="openCancelOrderModal(@order.OrderID)">
                            <i class="bi bi-x-circle me-1"></i>Hủy đơn
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="kanban-column">
        <div class="kanban-header text-success">
            <span><i class="bi bi-bell me-2"></i>Sẵn Sàng</span>
            <span class="badge bg-success rounded-pill">@Model.ReadyOrdersCount</span>
        </div>
        <div id="ready-orders">
            @foreach (var order in Model.ReadyOrders)
            {
                <div class="order-card" style="border-left-color: var(--success-color);" id="order-@order.OrderID">
                    <div class="order-header">
                        <span class="table-badge bg-success">@order.TableName</span>
                        <span class="order-time"><i class="bi bi-clock me-1"></i>@order.OrderTime.ToString("HH:mm")</span>
                    </div>
                    <div class="mb-2 text-muted small">#@order.OrderCode</div>
                    <ul class="order-items">
                        @foreach (var item in order.Items)
                        {
                            <li class="order-item">
                                <div class="d-flex w-100">
                                    <span class="item-qty">@item.Quantity</span>
                                    <div class="flex-grow-1">
                                        <div class="item-name">
                                            @item.DishName
                                            <button type="button"
                                                    class="btn btn-xs btn-outline-secondary ms-1"
                                                    style="padding:0 6px;font-size:11px;border-radius:999px;"
                                                    onclick="openOrderItemIngredients(@item.ItemID)">
                                                Thành phần
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </li>
                        }
                    </ul>
                    <div class="alert alert-success mt-2 p-2 small text-center">
                        <i class="bi bi-bell-fill me-1"></i>Đã báo phục vụ
                    </div>
                    <button class="btn btn-outline-danger btn-action mt-2" onclick="openCancelOrderModal(@order.OrderID)">
                        <i class="bi bi-x-circle me-1"></i>Hủy đơn
                    </button>
                </div>
            }
        </div>
    </div>
</div>
