@model SelfRestaurant.Gateway.Mvc.Areas.Admin.Models.AdminDishIngredientsViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Bếp - Nguyên liệu món";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="m-0">Nguyên liệu món: @Model.DishName</h2>
            <div class="text-muted small">Dish ID: @Model.DishId</div>
        </div>
        <a class="btn btn-outline-secondary btn-sm" asp-area="Staff" asp-controller="Chef" asp-action="Index">Quay lại dashboard</a>
    </div>

    @if (TempData["Success"] is string success)
    {
        <div class="alert alert-success">@success</div>
    }
    @if (TempData["Error"] is string error)
    {
        <div class="alert alert-danger">@error</div>
    }

    <form method="post" asp-area="Staff" asp-controller="Chef" asp-action="Ingredients" asp-route-id="@Model.DishId">
        @Html.AntiForgeryToken()
        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th>Chọn</th>
                        <th>Nguyên liệu</th>
                        <th>Đơn vị</th>
                        <th>Tồn kho</th>
                        <th>SL / món</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Lines.Count == 0)
                {
                    <tr><td colspan="5" class="text-muted">Không có dữ liệu.</td></tr>
                }
                else
                {
                    foreach (var line in Model.Lines)
                    {
                        <tr>
                            <td>
                                <input type="checkbox" class="form-check-input ingredient-check" data-target="qty-@line.IngredientId" @(line.Selected ? "checked" : "") />
                                <input type="hidden" name="ingredientId" value="@line.IngredientId" />
                            </td>
                            <td>@line.Name @(line.IsActive ? "" : "(Ngưng)")</td>
                            <td>@line.Unit</td>
                            <td>@line.CurrentStock</td>
                            <td>
                                <input id="qty-@line.IngredientId"
                                       class="form-control form-control-sm"
                                       type="number"
                                       step="0.001"
                                       min="0"
                                       name="quantityPerDish"
                                       value="@(line.Selected ? line.QuantityPerDish : 0)" />
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
        <button class="btn btn-danger" type="submit">Lưu nguyên liệu</button>
    </form>
</div>

@section Scripts {
<script>
    document.querySelectorAll('.ingredient-check').forEach(function (el) {
        el.addEventListener('change', function () {
            var input = document.getElementById(el.dataset.target);
            if (!input) return;
            if (el.checked && (!input.value || Number(input.value) <= 0)) {
                input.value = 1;
            }
            if (!el.checked) {
                input.value = 0;
            }
        });
    });
</script>
}
