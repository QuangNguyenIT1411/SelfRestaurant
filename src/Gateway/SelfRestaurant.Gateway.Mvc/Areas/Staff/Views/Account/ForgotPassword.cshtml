@{
    ViewBag.Title = "Quên Mật Khẩu Nhân Viên";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section css{
    <style>
        .auth-wrapper {
            min-height: calc(100vh - 120px);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1.5rem 0;
        }

        .forgot-container {
            background-color: white;
            border-radius: 16px;
            box-shadow: 0 6px 20px rgba(15, 23, 42, 0.08);
            max-width: 460px;
            width: 100%;
            padding: 2rem 1.75rem;
        }

        .forgot-header {
            text-align: center;
            margin-bottom: 1.5rem;
        }

            .forgot-header .icon {
                font-size: 3.5rem;
                color: #d9534f;
                margin-bottom: 1rem;
            }

        .form-group {
            margin-bottom: 1.5rem;
        }

        .btn-submit {
            background-color: #d9534f;
            border: none;
            padding: 0.75rem;
            font-weight: 600;
            border-radius: 8px;
            transition: background-color 0.3s ease;
            width: 100%;
            margin-bottom: 1rem;
        }

            .btn-submit:hover {
                background-color: #c9423f;
            }

        .back-to-login {
            text-align: center;
            color: #6c757d;
            font-size: 0.95rem;
        }

            .back-to-login a {
                color: #667eea;
                text-decoration: none;
                font-weight: 600;
            }

        .invalid-feedback {
            display: block;
            color: #dc3545;
            font-size: 0.875rem;
            margin-top: 0.25rem;
        }
    </style>
}

<div class="auth-wrapper">
    <div class="forgot-container">
        <div class="forgot-header">
            <div class="icon">
                <i class="fas fa-lock"></i>
            </div>
            <h1>Quên Mật Khẩu</h1>
            <p>Nhập email tài khoản nhân viên, hệ thống sẽ gửi link đặt lại mật khẩu.</p>
        </div>

        <form id="forgot-form">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label for="email">
                    <i class="fas fa-envelope me-2"></i>Email
                </label>
                <input type="email"
                       class="form-control"
                       id="email"
                       name="email"
                       placeholder="Nhập email đăng ký"
                       required />
                <div class="invalid-feedback" id="email-error"></div>
            </div>

            <button type="submit" class="btn btn-submit btn-danger">
                <i class="fas fa-paper-plane me-2"></i>
                <span id="btn-text">Gửi Link Đặt Lại Mật Khẩu</span>
            </button>

            <div class="back-to-login">
                <i class="fas fa-arrow-left me-2"></i>
                <a href="@Url.Action("Login", "Account", new { area = "Staff" })">Quay lại đăng nhập</a>
            </div>
        </form>

        <div id="alert-message"></div>
    </div>
</div>

@section scripts{
    <script>
        document.getElementById('forgot-form').addEventListener('submit', function (e) {
            e.preventDefault();

            const email = document.getElementById('email').value.trim();
            const btnSubmit = document.querySelector('button[type="submit"]');
            const btnText = document.getElementById('btn-text');
            const alertDiv = document.getElementById('alert-message');

            document.getElementById('email-error').textContent = '';
            alertDiv.innerHTML = '';

            if (!email) {
                document.getElementById('email-error').textContent = 'Vui lòng nhập email';
                return;
            }

            btnSubmit.disabled = true;
            btnText.innerHTML = 'Đang gửi...';

            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            const formData = new FormData();
            formData.append('email', email);
            formData.append('__RequestVerificationToken', token);

            fetch('@Url.Action("ForgotPassword", "Account", new { area = "Staff" })', {
                method: 'POST',
                body: formData
            })
                .then(response => response.json())
                .then(data => {
                    alertDiv.innerHTML = `
                        <div class="alert alert-${data.success ? 'success' : 'danger'}" role="alert">
                            <i class="fas fa-info-circle me-2"></i>
                            ${data.message}
                        </div>`;

                    btnSubmit.disabled = false;
                    btnText.innerHTML = '<i class="fas fa-paper-plane me-2"></i>Gửi Link Đặt Lại Mật Khẩu';
                    if (data.success) {
                        document.getElementById('email').value = '';
                    }
                })
                .catch(error => {
                    alertDiv.innerHTML = `
                        <div class="alert alert-danger" role="alert">
                            <i class="fas fa-exclamation-circle me-2"></i>
                            Có lỗi xảy ra. Vui lòng thử lại sau.
                        </div>`;
                    btnSubmit.disabled = false;
                    btnText.innerHTML = '<i class="fas fa-paper-plane me-2"></i>Gửi Link Đặt Lại Mật Khẩu';
                });
        });
    </script>
}

