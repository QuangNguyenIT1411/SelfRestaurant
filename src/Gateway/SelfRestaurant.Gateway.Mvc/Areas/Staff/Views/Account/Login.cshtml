@{
    ViewBag.Title = "Đăng Nhập";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section css{
    <style>
        body {
            font-family: "Inter", sans-serif;
            background-color: #f0f2f5;
        }

        .login-container {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: 2rem;
        }

        .login-card {
            width: 100%;
            max-width: 450px;
            border: none;
            border-radius: 16px;
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
            background-color: #ffffff;
            padding: 2.5rem;
        }

        .login-header {
            text-align: center;
            margin-bottom: 2rem;
        }

        .login-brand {
            font-weight: 700;
            font-size: 2.5rem;
            color: #d9534f;
            margin-bottom: 0.5rem;
        }

        .login-title {
            font-size: 1.2rem;
            color: #6c757d;
            font-weight: 500;
        }

        .form-floating > .form-control {
            height: calc(3.8rem + 2px);
            line-height: 1.25;
            padding-top: 1.625rem;
            padding-bottom: 0.625rem;
            padding-left: 3.5rem;
        }

        .form-floating > label {
            padding-top: 1.15rem;
            padding-left: 3.5rem;
            font-size: 1rem;
        }

        .form-floating {
            position: relative;
        }

            .form-floating .form-icon {
                position: absolute;
                top: 50%;
                left: 1.25rem;
                transform: translateY(-50%);
                color: #adb5bd;
                font-size: 1.1rem;
                z-index: 10;
            }

        .btn-login {
            font-size: 1.1rem;
            font-weight: 600;
            padding: 0.85rem 1.5rem;
            border-radius: 8px;
            background-color: #d9534f;
            border-color: #d9534f;
        }

            .btn-login:hover:not(:disabled) {
                background-color: #c9302c;
                border-color: #ac2925;
            }

            .btn-login:disabled {
                opacity: 0.6;
                cursor: not-allowed;
            }

        .form-check-label {
            font-weight: 500;
        }

        .forgot-password {
            font-size: 0.9rem;
            font-weight: 500;
            color: #d9534f;
            text-decoration: none;
        }

            .forgot-password:hover {
                text-decoration: underline;
            }

        .spinner-border-sm {
            width: 1rem;
            height: 1rem;
            border-width: 0.15em;
        }

        .password-toggle {
            position: relative;
        }

        .password-toggle-icon {
            position: absolute;
            right: 1rem;
            top: 50%;
            transform: translateY(-50%);
            cursor: pointer;
            color: #adb5bd;
            z-index: 11;
        }

            .password-toggle-icon:hover {
                color: #6c757d;
            }
    </style>
}

<div class="login-container">
    <div class="login-card">
        <!-- Header logo và tiêu đề -->
        <div class="login-header">
            <h1 class="login-brand">Self Restaurant</h1>
            <p class="login-title">Đăng nhập tài khoản quản lý</p>
        </div>

        <!-- Thêm đoạn code này NGAY SAU div.login-header trong Login.cshtml -->
        <!-- Hiển thị thông báo thành công (khi logout) -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle me-2"></i>
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <!-- Hiển thị thông báo lỗi (nếu có) -->
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-triangle me-2"></i>
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <!-- Form đăng nhập -->
        <form id="loginForm">
            @Html.AntiForgeryToken()

            <!-- Ô nhập Tên đăng nhập -->
            <div class="form-floating mb-3">
                <i class="fas fa-user form-icon"></i>
                <input type="text"
                       class="form-control"
                       id="username"
                       name="username"
                       placeholder="Tên đăng nhập"
                       required
                       autocomplete="username" />
                <label for="username">Tên đăng nhập</label>
            </div>

            <!-- Ô nhập Mật khẩu -->
            <div class="form-floating mb-3 password-toggle">
                <i class="fas fa-lock form-icon"></i>
                <input type="password"
                       class="form-control"
                       id="password"
                       name="password"
                       placeholder="Mật khẩu"
                       required
                       autocomplete="current-password" />
                <label for="password">Mật khẩu</label>
                <i class="fas fa-eye password-toggle-icon" id="togglePassword"></i>
            </div>

            <!-- Tùy chọn Ghi nhớ và Quên mật khẩu -->
            <div class="d-flex justify-content-between align-items-center mb-4 mt-4">
                <div class="form-check">
                    <input class="form-check-input"
                           type="checkbox"
                           name="rememberMe"
                           id="rememberMe" />
                    <label class="form-check-label" for="rememberMe">
                        Ghi nhớ tôi
                    </label>
                </div>
                <a href="@Url.Action("ForgotPassword", "Account", new { area = "Staff" })" class="forgot-password">Quên mật khẩu?</a>
            </div>

            <!-- Nút Đăng nhập -->
            <div class="d-grid">
                <button class="btn btn-danger btn-login" type="submit" id="btnLogin">
                    <i class="fas fa-sign-in-alt me-2"></i>
                    <span id="btnText">Đăng Nhập</span>
                    <span id="btnSpinner" class="spinner-border spinner-border-sm ms-2 d-none" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </span>
                </button>
            </div>
        </form>

        <!-- Thông báo -->
        <div id="loginAlert" class="alert mt-4 d-none" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i>
            <span id="alertMessage"></span>
        </div>

        <!-- Thông tin test accounts -->
        <div class="mt-4 p-3" style="background-color: #f8f9fa; border-radius: 8px; font-size: 0.85rem;">
            <strong>Tài khoản test:</strong><br />
            Admin: <code>admin</code> / <code>123456</code><br />
            Thu ngân: <code>cashier_lan</code> / <code>123456</code><br />
            Đầu bếp: <code>chef_hung</code> / <code>123456</code>
        </div>
    </div>
</div>

@section scripts{
    <script>
        $(document).ready(function () {
            $('#loginForm').on('submit', function (e) {
                e.preventDefault();

                const username = $('#username').val().trim();
                const password = $('#password').val();
                const rememberMe = $('#rememberMe').is(':checked');
                const $btnLogin = $('#btnLogin');
                const $btnText = $('#btnText');
                const $btnSpinner = $('#btnSpinner');
                const $alert = $('#loginAlert');

                // Ẩn thông báo cũ
                $alert.addClass('d-none').removeClass('alert-danger alert-success');

                // Validate
                if (!username) {
                    showAlert('Vui lòng điền tên đăng nhập.', 'danger');
                    return;
                }

                if (!password) {
                    showAlert('Vui lòng nhập mật khẩu.', 'danger');
                    return;
                }

                // Disable button và hiện spinner
                $btnLogin.prop('disabled', true);
                $btnSpinner.removeClass('d-none');

                // Lấy anti-forgery token
                const token = $('input[name="__RequestVerificationToken"]').val();

                // Gửi request đăng nhập
                $.ajax({
                    url: '@Url.Action("Login", "Account")',
                    type: 'POST',
                    data: {
                        __RequestVerificationToken: token,
                        username: username,
                        password: password,
                        rememberMe: rememberMe
                    },
                    success: function (response) {
                        if (response.success) {
                            showAlert('Đăng nhập thành công! Đang chuyển hướng...', 'success');

                            // Chuyển hướng sau 1 giây
                            setTimeout(function () {
                                window.location.href = response.redirectUrl;
                            }, 1000);
                        } else {
                            showAlert(response.message || 'Đăng nhập thất bại.', 'danger');
                            $btnLogin.prop('disabled', false);
                            $btnSpinner.addClass('d-none');
                        }
                    },
                    error: function (xhr, status, error) {
                        showAlert('Có lỗi xảy ra. Vui lòng thử lại.', 'danger');
                        $btnLogin.prop('disabled', false);
                        $btnSpinner.addClass('d-none');
                    }
                });
            });

            function showAlert(message, type) {
                const $alert = $('#loginAlert');
                const $alertMessage = $('#alertMessage');

                $alertMessage.text(message);
                $alert.removeClass('d-none alert-danger alert-success')
                      .addClass('alert-' + type);
            }

            // Toggle show/hide password
            const passwordInput = document.getElementById('password');
            const toggleIcon = document.getElementById('togglePassword');
            if (passwordInput && toggleIcon) {
                toggleIcon.addEventListener('click', function () {
                    const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
                    passwordInput.setAttribute('type', type);
                    this.classList.toggle('fa-eye');
                    this.classList.toggle('fa-eye-slash');
                });
            }
        });
    </script>
}
