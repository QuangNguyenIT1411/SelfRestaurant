@model SelfRestaurant.Gateway.Mvc.Areas.Admin.Models.AdminEmployeeFormViewModel
@{
    ViewBag.Title = "Thêm nhân viên";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var branchItems = new SelectList(Model.Branches, "BranchId", "Name", Model.BranchId);
    var roleItems = new SelectList(Model.Roles, "RoleId", "RoleName", Model.RoleId);
}

@section css{
    <style>
        body {
            background: linear-gradient(135deg, #f7f9fc 0%, #eef2ff 35%, #e6ecff 70%, #ffffff 100%);
        }

        .page-title {
            font-weight: 800;
            letter-spacing: -0.4px;
            color: #0b132b;
        }

        .card {
            border-radius: 16px;
            border: 1px solid #e5e7f0;
            box-shadow: 0 15px 45px rgba(15, 23, 42, 0.06);
        }

        .form-label {
            font-weight: 600;
            color: #111827;
        }

        .form-control, .form-select {
            border-radius: 12px;
            padding: 12px 14px;
            border-color: #d5daf0;
        }

        .form-control:focus, .form-select:focus {
            border-color: #5b7bff;
            box-shadow: 0 0 0 0.2rem rgba(91, 123, 255, 0.15);
        }

        .card-footer {
            border-top: 1px dashed #e2e8f0;
        }
    </style>
}

<div class="container py-4">
    <div class="row g-3">
        <div class="col-lg-3">
            @await Html.PartialAsync("~/Areas/Admin/Views/Shared/_AdminSidebar.cshtml")
        </div>
        <div class="col-lg-9">
            <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
                <div>
                    <h1 class="page-title mb-1">Thêm nhân viên mới</h1>
                    <p class="text-muted mb-0">Tạo tài khoản đăng nhập, phân quyền và gán chi nhánh cho nhân viên.</p>
                </div>
                <a href="@Url.Action("Index", "Employees", new { area = "Admin" })" class="btn btn-outline-secondary btn-lg">
                    <i class="bi bi-arrow-left me-2"></i>Quay lại danh sách
                </a>
            </div>

            @using (Html.BeginForm("Create", "Employees", new { area = "Admin" }, FormMethod.Post, false, new { }))
            {
                @Html.AntiForgeryToken()
                <div class="card">
                    <div class="card-body">
                        @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })
                        <div class="row g-4">
                            <div class="col-md-6">
                                <label class="form-label">Họ tên</label>
                                @Html.TextBoxFor(m => m.Name, new { @class = "form-control form-control-lg", placeholder = "Nguyễn Văn A", required = "required" })
                                @Html.ValidationMessageFor(m => m.Name, "", new { @class = "text-danger small" })
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Tên đăng nhập</label>
                                @Html.TextBoxFor(m => m.Username, new { @class = "form-control form-control-lg", placeholder = "employee01", required = "required" })
                                @Html.ValidationMessageFor(m => m.Username, "", new { @class = "text-danger small" })
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Mật khẩu</label>
                                @Html.PasswordFor(m => m.Password, new { @class = "form-control form-control-lg", placeholder = "••••••••", required = "required" })
                                @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger small" })
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">Số điện thoại</label>
                                @Html.TextBoxFor(m => m.Phone, new { @class = "form-control form-control-lg", placeholder = "0901234567" })
                                @Html.ValidationMessageFor(m => m.Phone, "", new { @class = "text-danger small" })
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Email</label>
                                @Html.TextBoxFor(m => m.Email, new { @class = "form-control form-control-lg", placeholder = "staff@example.com", type = "email" })
                                @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small" })
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Ca làm việc</label>
                                @Html.TextBoxFor(m => m.Shift, new { @class = "form-control form-control-lg", placeholder = "Sáng / Chiều / Tối" })
                                @Html.ValidationMessageFor(m => m.Shift, "", new { @class = "text-danger small" })
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">Lương (VNĐ)</label>
                                @Html.TextBoxFor(m => m.Salary, new { @class = "form-control form-control-lg", type = "number", step = "1000", min = "0", placeholder = "10000000" })
                                @Html.ValidationMessageFor(m => m.Salary, "", new { @class = "text-danger small" })
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Chi nhánh</label>
                                @Html.DropDownListFor(m => m.BranchId, branchItems, "Chọn chi nhánh", new { @class = "form-select form-select-lg", required = "required" })
                                @Html.ValidationMessageFor(m => m.BranchId, "", new { @class = "text-danger small" })
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Vai trò</label>
                                @Html.DropDownListFor(m => m.RoleId, roleItems, "Chọn vai trò", new { @class = "form-select form-select-lg", required = "required" })
                                @Html.ValidationMessageFor(m => m.RoleId, "", new { @class = "text-danger small" })
                            </div>

                            <div class="col-md-4">
                                <label class="form-label d-block">Trạng thái</label>
                                <div class="form-check form-switch">
                                    @Html.CheckBox("IsActive", Model?.IsActive ?? true, new { @class = "form-check-input", role = "switch" })
                                    <label class="form-check-label">Cho phép đăng nhập và hoạt động</label>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer d-flex justify-content-between align-items-center bg-white py-3">
                        <div class="text-muted small">
                            Nhân viên sẽ được tạo ngay sau khi lưu. Bạn có thể sửa hoặc vô hiệu hóa bất kỳ lúc nào.
                        </div>
                        <div class="d-flex gap-2">
                            <a href="@Url.Action("Index", "Employees", new { area = "Admin" })" class="btn btn-outline-secondary">Hủy</a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save me-2"></i>Lưu nhân viên
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
