@model SelfRestaurant.Gateway.Mvc.Areas.Admin.Models.AdminIngredientsIndexViewModel
@{
    ViewBag.Title = "Quản lý nguyên liệu";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var items = Model?.Items ?? Array.Empty<SelfRestaurant.Gateway.Mvc.Models.AdminIngredientDto>();
    var search = Model?.Search;
    bool? onlyActive = Model?.OnlyActive;
    var page = Model?.Page ?? 1;
    var totalPages = Model?.TotalPages ?? 1;
}

<div class="container py-4">
    <div class="row g-3">
        <div class="col-lg-3">
            @await Html.PartialAsync("~/Areas/Admin/Views/Shared/_AdminSidebar.cshtml")
        </div>
        <div class="col-lg-9">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="mb-0">Quản lý nguyên liệu</h2>
                <a href="@Url.Action("Create")" class="btn btn-primary">
                    <i class="bi bi-plus-lg me-1"></i>Thêm nguyên liệu
                </a>
            </div>

            @if (ViewBag.SuccessMessage != null)
            {
                <div class="alert alert-success">@ViewBag.SuccessMessage</div>
            }
            @if (ViewBag.ErrorMessage != null)
            {
                <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
            }

            <form method="get" class="row g-2 mb-3">
                <div class="col-md-5">
                    <input type="text" name="search" value="@search" class="form-control" placeholder="Tìm theo tên hoặc đơn vị..." />
                </div>
                <div class="col-md-3">
                    <div class="form-check mt-2">
                        <input class="form-check-input" type="checkbox" value="true" id="onlyActive" name="onlyActive" @(onlyActive == null || onlyActive == false ? "" : "checked") />
                        <label class="form-check-label" for="onlyActive">
                            Chỉ hiển thị đang sử dụng
                        </label>
                    </div>
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-outline-primary w-100">
                        <i class="bi bi-search me-1"></i>Lọc
                    </button>
                </div>
            </form>

            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Tên nguyên liệu</th>
                            <th>Đơn vị</th>
                            <th class="text-end">Tồn kho</th>
                            <th class="text-end">Mức cảnh báo</th>
                            <th>Trạng thái</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!items.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">Chưa có nguyên liệu nào.</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in items)
                            {
                                var isLow = item.CurrentStock <= item.ReorderLevel && item.IsActive;
                                <tr class="@(item.IsActive ? "" : "table-secondary")">
                                    <td>@item.Name</td>
                                    <td>@item.Unit</td>
                                    <td class="text-end">@item.CurrentStock.ToString("N2")</td>
                                    <td class="text-end">@item.ReorderLevel.ToString("N2")</td>
                                    <td>
                                        @if (!item.IsActive)
                                        {
                                            <span class="badge bg-secondary">Ngừng sử dụng</span>
                                        }
                                        else if (isLow)
                                        {
                                            <span class="badge bg-warning text-dark">Sắp hết</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Đủ hàng</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <a href="@Url.Action("Edit", new { id = item.IngredientId })" class="btn btn-sm btn-outline-primary me-1">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        @using (Html.BeginForm("Deactivate", "Ingredients", FormMethod.Post, new { area = "Admin", onsubmit = "return confirm('Ngừng sử dụng nguyên liệu này?');", @class = "d-inline" }))
                                        {
                                            @Html.AntiForgeryToken()
                                            @Html.Hidden("id", item.IngredientId)
                                            <button type="submit" class="btn btn-sm btn-outline-danger" @(item.IsActive ? "" : "disabled")>
                                                <i class="bi bi-slash-circle"></i>
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            @if (totalPages > 1)
            {
                <nav class="mt-3">
                    <ul class="pagination">
                        <li class="page-item @(page <= 1 ? "disabled" : "")">
                            <a class="page-link" href="@Url.Action("Index", new { page = page - 1, search = search, onlyActive = onlyActive })">«</a>
                        </li>
                        @for (int p = 1; p <= totalPages; p++)
                        {
                            <li class="page-item @(p == page ? "active" : "")">
                                <a class="page-link" href="@Url.Action("Index", new { page = p, search = search, onlyActive = onlyActive })">@p</a>
                            </li>
                        }
                        <li class="page-item @(page >= totalPages ? "disabled" : "")">
                            <a class="page-link" href="@Url.Action("Index", new { page = page + 1, search = search, onlyActive = onlyActive })">»</a>
                        </li>
                    </ul>
                </nav>
            }
        </div>
    </div>
</div>
