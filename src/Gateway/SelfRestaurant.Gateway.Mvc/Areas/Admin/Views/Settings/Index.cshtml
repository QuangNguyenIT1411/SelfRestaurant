@model SelfRestaurant.Gateway.Mvc.Areas.Admin.Models.AdminSettingsViewModel
@{
    ViewBag.Title = "Cài đặt tài khoản";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section css{
    <style>
        body {
            background: radial-gradient(circle at 10% 10%, #f5f9ff, #eef2ff 40%, #ffffff 100%);
        }

        .page-title {
            font-weight: 800;
            letter-spacing: -0.4px;
            color: #0b132b;
        }

        .card {
            border-radius: 16px;
            border: 1px solid #e5e7f0;
            box-shadow: 0 15px 45px rgba(15, 23, 42, 0.06);
        }

        .form-label {
            font-weight: 600;
            color: #111827;
        }

        .form-control {
            border-radius: 12px;
            padding: 12px 14px;
            border-color: #d5daf0;
        }

            .form-control:focus {
                border-color: #5b7bff;
                box-shadow: 0 0 0 0.2rem rgba(91, 123, 255, 0.15);
            }
    </style>
}

<div class="container py-4">
    <div class="row g-3">
        <div class="col-lg-3">
            @await Html.PartialAsync("~/Areas/Admin/Views/Shared/_AdminSidebar.cshtml")
        </div>
        <div class="col-lg-9">
            <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
                <div>
                    <h1 class="page-title mb-1">Cài đặt tài khoản</h1>
                    <p class="text-muted mb-0">Cập nhật thông tin cá nhân và mật khẩu.</p>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(ViewBag.SuccessMessage as string))
            {
                <div class="alert alert-success">@ViewBag.SuccessMessage</div>
            }
            @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage as string))
            {
                <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
            }

            @using (Html.BeginForm("Index", "Settings", FormMethod.Post, new { area = "Admin" }))
            {
                @Html.AntiForgeryToken()
                <div class="card">
                    <div class="card-body">
                        @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

                        <div class="row g-4">
                            <div class="col-md-6">
                                <label class="form-label">Họ tên</label>
                                @Html.TextBoxFor(m => m.Name, new { @class = "form-control form-control-lg", required = "required" })
                                @Html.ValidationMessageFor(m => m.Name, "", new { @class = "text-danger small" })
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Tài khoản</label>
                                @Html.TextBoxFor(m => m.Username, new { @class = "form-control form-control-lg", @readonly = "readonly" })
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Số điện thoại</label>
                                @Html.TextBoxFor(m => m.Phone, new { @class = "form-control form-control-lg" })
                                @Html.ValidationMessageFor(m => m.Phone, "", new { @class = "text-danger small" })
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Email</label>
                                @Html.TextBoxFor(m => m.Email, new { @class = "form-control form-control-lg", type = "email" })
                                @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small" })
                            </div>

                            <div class="col-12">
                                <hr />
                                <h5>Đổi mật khẩu</h5>
                                <p class="text-muted small mb-3">
                                    Nếu không muốn đổi mật khẩu, hãy để trống các ô bên dưới.
                                </p>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">Mật khẩu hiện tại</label>
                                @Html.PasswordFor(m => m.CurrentPassword, new { @class = "form-control form-control-lg" })
                                @Html.ValidationMessageFor(m => m.CurrentPassword, "", new { @class = "text-danger small" })
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Mật khẩu mới</label>
                                @Html.PasswordFor(m => m.NewPassword, new { @class = "form-control form-control-lg" })
                                @Html.ValidationMessageFor(m => m.NewPassword, "", new { @class = "text-danger small" })
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Nhập lại mật khẩu mới</label>
                                @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "form-control form-control-lg" })
                                @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger small" })
                            </div>
                        </div>
                    </div>
                    <div class="card-footer d-flex justify-content-end bg-white py-3">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save me-2"></i>Lưu thay đổi
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

