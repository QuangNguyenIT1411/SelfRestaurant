@model SelfRestaurant.Gateway.Mvc.Areas.Admin.Models.AdminDishFormViewModel
@{
    ViewBag.Title = "Sửa món ăn";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="row g-3">
        <div class="col-lg-3">
            @Html.Partial("~/Areas/Admin/Views/Shared/_AdminSidebar.cshtml")
        </div>
        <div class="col-lg-9">
            <h2 class="mb-3">Sửa món ăn</h2>

            @using (Html.BeginForm(null, null, FormMethod.Post, new { enctype = "multipart/form-data" }))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(m => m.DishID)

                if (ViewBag.ErrorMessage != null)
                {
                    <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
                }

                <div class="mb-3">
                    @Html.LabelFor(m => m.Name, new { @class = "form-label" })
                    @Html.TextBoxFor(m => m.Name, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.Name, "", new { @class = "text-danger" })
                </div>

                <div class="row g-3">
                    <div class="col-md-4">
                        @Html.LabelFor(m => m.Price, new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.Price, new { @class = "form-control", type = "number", step = "1000", min = "0" })
                        @Html.ValidationMessageFor(m => m.Price, "", new { @class = "text-danger" })
                    </div>
                    <div class="col-md-4">
                        @Html.LabelFor(m => m.Unit, new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.Unit, new { @class = "form-control", placeholder = "Tô, Phần, Ly..." })
                    </div>
                    <div class="col-md-4">
                        @Html.Label("Danh mục", null, new { @class = "form-label" })
                        @Html.DropDownList("CategoryID", (SelectList)ViewBag.Categories, "-- Chọn danh mục --", new { @class = "form-select" })
                        @Html.ValidationMessage("CategoryID", "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="mb-3 mt-3">
                    @Html.Label("imageFile", "Hình ảnh món ăn", new { @class = "form-label" })
                    <input type="file" name="imageFile" id="imageFile" class="form-control" accept="image/*" onchange="previewDishImage(this)" />
                    <div class="form-text">Chọn file hình mới nếu muốn thay đổi.</div>
                    <div class="mt-2">
                        <img id="imagePreview" src="@(string.IsNullOrEmpty(Model.Image) ? "https://placehold.co/120x80?text=Preview" : Url.Content(Model.Image))"
                             style="max-width: 200px; max-height: 150px; border-radius: 6px; object-fit: cover;" />
                    </div>
                </div>

                <div class="mb-3">
                    @Html.LabelFor(m => m.Description, "Mô tả món ăn", new { @class = "form-label" })
                    @Html.TextAreaFor(m => m.Description, 4, 50, new { @class = "form-control" })
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-4 form-check">
                        @Html.CheckBox("Available", Model.Available,
                                 new { @class = "form-check-input", id = "chkAvailable" })
                        <label class="form-check-label" for="chkAvailable">Đang bán</label>
                    </div>
                    <div class="col-md-4 form-check">
                        @Html.CheckBox("IsVegetarian", Model.IsVegetarian,
                                 new { @class = "form-check-input", id = "chkVeg" })
                        <label class="form-check-label" for="chkVeg">Món chay</label>
                    </div>
                    <div class="col-md-4 form-check">
                        @Html.CheckBox("IsDailySpecial", Model.IsDailySpecial,
                                 new { @class = "form-check-input", id = "chkSpecial" })
                        <label class="form-check-label" for="chkSpecial">Món đặc biệt trong ngày</label>
                    </div>
                </div>

                <div class="mb-3 form-check">
                    @Html.CheckBox("IsActive", Model.IsActive,
                             new { @class = "form-check-input", id = "chkActive" })
                    <label class="form-check-label" for="chkActive">Kích hoạt trong hệ thống</label>
                </div>

                <div class="d-flex justify-content-between">
                    <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i>Quay lại
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save me-1"></i>Lưu thay đổi
                    </button>
                </div>
            }
        </div>
    </div>
</div>

@section scripts{
    <script>function previewDishImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    var img = document.getElementById("imagePreview");
                    if (img) {
                        img.src = e.target.result;
                    }
                };
                reader.readAsDataURL(input.files[0]);
            }
        }</script>
}
