@model SelfRestaurant.Gateway.Mvc.Areas.Admin.Models.AdminTablesIndexViewModel
@{
    ViewBag.Title = "Quản lý bàn và QR";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var items = Model?.Items ?? Array.Empty<SelfRestaurant.Gateway.Mvc.Models.AdminTableDto>();
    var branches = Model?.Branches ?? Array.Empty<SelfRestaurant.Gateway.Mvc.Models.BranchDto>();
    var search = Model?.Search ?? string.Empty;
    var branchId = Model?.BranchId;
    var page = Model?.Page ?? 1;
    var totalPages = Model?.TotalPages ?? 0;
}

<div class="container py-4">
    <div class="row g-3">
        <div class="col-lg-3">
            @await Html.PartialAsync("~/Areas/Admin/Views/Shared/_AdminSidebar.cshtml")
        </div>
        <div class="col-lg-9">
            <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
                <div>
                    <h1 class="page-title mb-1">Quản lý bàn và QR</h1>
                    <p class="text-muted mb-0">Quản lý bàn theo chi nhánh, số chỗ ngồi và trạng thái sử dụng.</p>
                </div>
                <a asp-area="Admin" asp-controller="Tables" asp-action="Create" class="btn btn-primary btn-lg shadow-sm">
                    <i class="bi bi-plus-circle me-2"></i>Thêm bàn
                </a>
            </div>

            @if (ViewBag.SuccessMessage != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>@ViewBag.SuccessMessage
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (ViewBag.ErrorMessage != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@ViewBag.ErrorMessage
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <form method="get" asp-area="Admin" asp-controller="Tables" asp-action="Index" class="filter-card card-hero mb-4">
                <div class="card-body">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Chi nhánh</label>
                            <select class="form-select form-select-lg" name="branchId">
                                <option value="">Tất cả chi nhánh</option>
                                @foreach (var branch in branches)
                                {
                                    <option value="@branch.BranchId" selected="@(branchId == branch.BranchId)">@branch.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-5">
                            <label class="form-label fw-semibold">Từ khóa</label>
                            <input class="form-control form-control-lg" name="search" value="@search" placeholder="Tìm theo mã bàn / QR" />
                        </div>
                        <div class="col-md-3">
                            <button class="btn btn-dark btn-lg w-100" type="submit">
                                <i class="bi bi-funnel-fill me-1"></i>Lọc
                            </button>
                        </div>
                    </div>
                </div>
            </form>

            <div class="card card-hero">
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Chi nhánh</th>
                                <th>Số chỗ</th>
                                <th>Mã QR</th>
                                <th>Trạng thái bàn</th>
                                <th>Kích hoạt</th>
                                <th class="text-end">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!items.Any())
                            {
                                <tr>
                                    <td colspan="7" class="text-center py-4 text-muted">Chưa có bàn nào.</td>
                                </tr>
                            }
                            else
                            {
                                foreach (var table in items)
                                {
                                    <tr>
                                        <td>@table.TableId</td>
                                        <td>@table.BranchName</td>
                                        <td>@table.NumberOfSeats</td>
                                        <td><code>@table.QRCode</code></td>
                                        <td>
                                            <span class="badge bg-info-subtle text-info-emphasis">@table.StatusName</span>
                                            <div class="small text-muted">@table.StatusCode</div>
                                        </td>
                                        <td>
                                            @if (table.IsActive)
                                            {
                                                <span class="badge badge-soft-success">Hoạt động</span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-soft-danger">Ngừng</span>
                                            }
                                        </td>
                                        <td class="text-end">
                                            <a asp-area="Admin" asp-controller="Tables" asp-action="Edit" asp-route-id="@table.TableId" class="btn btn-sm btn-outline-primary me-2">
                                                <i class="bi bi-pencil-square me-1"></i>Sửa
                                            </a>
                                            @if (table.IsActive)
                                            {
                                                <form method="post" asp-area="Admin" asp-controller="Tables" asp-action="Deactivate" asp-route-id="@table.TableId" onsubmit="return confirm('Vô hiệu hóa bàn này?');" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <button class="btn btn-sm btn-outline-danger" type="submit">Vô hiệu</button>
                                                </form>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            @if (totalPages > 1)
            {
                <nav class="mt-3">
                    <ul class="pagination">
                        <li class="page-item @(page <= 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@(page - 1)" asp-route-branchId="@branchId" asp-route-search="@search">«</a>
                        </li>
                        @for (var p = 1; p <= totalPages; p++)
                        {
                            <li class="page-item @(p == page ? "active" : "")">
                                <a class="page-link" asp-action="Index" asp-route-page="@p" asp-route-branchId="@branchId" asp-route-search="@search">@p</a>
                            </li>
                        }
                        <li class="page-item @(page >= totalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@(page + 1)" asp-route-branchId="@branchId" asp-route-search="@search">»</a>
                        </li>
                    </ul>
                </nav>
            }
        </div>
    </div>
</div>
