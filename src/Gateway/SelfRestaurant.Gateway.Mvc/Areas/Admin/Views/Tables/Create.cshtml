@model SelfRestaurant.Gateway.Mvc.Areas.Admin.Models.AdminTableFormViewModel
@{
    ViewBag.Title = "Thêm bàn";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var vm = Model ?? new SelfRestaurant.Gateway.Mvc.Areas.Admin.Models.AdminTableFormViewModel();
    var branches = vm.Branches ?? Array.Empty<SelfRestaurant.Gateway.Mvc.Models.BranchDto>();
    var statuses = vm.Statuses ?? Array.Empty<SelfRestaurant.Gateway.Mvc.Models.TableStatusDto>();
}

<div class="container py-4">
    <div class="row g-3">
        <div class="col-lg-3">
            @await Html.PartialAsync("~/Areas/Admin/Views/Shared/_AdminSidebar.cshtml")
        </div>
        <div class="col-lg-9">
            <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
                <div>
                    <h1 class="page-title mb-1">Thêm bàn mới</h1>
                    <p class="text-muted mb-0">Tạo bàn theo chi nhánh và cấu hình QR sử dụng.</p>
                </div>
                <a asp-area="Admin" asp-controller="Tables" asp-action="Index" class="btn btn-outline-secondary btn-lg">
                    <i class="bi bi-arrow-left me-2"></i>Quay lại danh sách
                </a>
            </div>

            <form method="post" asp-area="Admin" asp-controller="Tables" asp-action="Create">
                @Html.AntiForgeryToken()
                <div class="card">
                    <div class="card-body">
                        @if (ViewBag.ErrorMessage != null)
                        {
                            <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
                        }

                        <div class="row g-4">
                            <div class="col-md-6">
                                <label class="form-label">Chi nhánh</label>
                                <select class="form-select form-select-lg" name="BranchId" required>
                                    <option value="">Chọn chi nhánh</option>
                                    @foreach (var branch in branches)
                                    {
                                        <option value="@branch.BranchId" selected="@(branch.BranchId == vm.BranchId)">@branch.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Số chỗ ngồi</label>
                                <input class="form-control form-control-lg" type="number" min="1" name="NumberOfSeats" value="@vm.NumberOfSeats" required />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Trạng thái bàn</label>
                                <select class="form-select form-select-lg" name="StatusId" required>
                                    @foreach (var status in statuses)
                                    {
                                        <option value="@status.StatusId" selected="@(status.StatusId == vm.StatusId)">@status.StatusName</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-8">
                                <label class="form-label">Mã QR (để trống để tự tạo)</label>
                                <input class="form-control form-control-lg" name="QRCode" value="@vm.QRCode" placeholder="TABLE-QR-..." />
                            </div>

                            <div class="col-md-4">
                                <label class="form-label d-block">Kích hoạt</label>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" name="IsActive" value="true" checked="@vm.IsActive" role="switch" />
                                    <label class="form-check-label">Bàn đang hoạt động</label>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer d-flex justify-content-between align-items-center bg-white py-3">
                        <div class="text-muted small">Mã QR có thể dùng cho khách quét gọi món tại bàn.</div>
                        <div class="d-flex gap-2">
                            <a asp-area="Admin" asp-controller="Tables" asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
                            <button class="btn btn-primary" type="submit"><i class="bi bi-save me-2"></i>Lưu bàn</button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
