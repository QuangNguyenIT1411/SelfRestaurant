@model SelfRestaurant.Gateway.Mvc.Areas.Admin.Models.AdminTopDishesReportViewModel
@using System.Collections.Generic
@{
    ViewBag.Title = "Món ăn được gọi nhiều nhất";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var items = Model?.Items ?? new List<SelfRestaurant.Gateway.Mvc.Models.AdminTopDishReportItemDto>();
}

@section css{
    <style>
        body {
            background: linear-gradient(135deg, #f2f6ff 0%, #eef2f7 50%, #f9fbff 100%);
            color: #0f172a;
        }

        .page-title {
            font-weight: 800;
            letter-spacing: -0.5px;
            color: #0b132b;
        }

        .card-hero {
            border: none;
            border-radius: 18px;
            box-shadow: 0 15px 40px rgba(15, 23, 42, 0.08);
        }

        .table > :not(caption) > * > * {
            padding: 14px 12px;
        }

        .table thead {
            background: #f6f8fb;
            text-transform: uppercase;
            font-size: 12px;
            letter-spacing: 0.04em;
        }

        .badge-soft {
            background: #eef2ff;
            color: #4338ca;
        }

        .empty-state {
            padding: 32px 16px;
            color: #6b7280;
            text-align: center;
        }
    </style>
}

<div class="container py-4">
    <div class="row g-3">
        <div class="col-lg-3">
            @await Html.PartialAsync("~/Areas/Admin/Views/Shared/_AdminSidebar.cshtml")
        </div>
        <div class="col-lg-9">
            <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
                <div>
                    <h1 class="page-title mb-1">Món ăn được gọi nhiều nhất</h1>
                    <p class="text-muted mb-0">Top món theo số lượng bán ra.</p>
                </div>
            </div>

            <div class="card card-hero">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <div>
                            <h5 class="mb-0">Top 10 món</h5>
                            <small class="text-muted">Xếp hạng theo số lượng bán, ưu tiên món có doanh thu cao hơn khi bằng nhau.</small>
                        </div>
                    </div>
                    @if (!items.Any())
                    {
                        <div class="empty-state">
                            <i class="bi bi-egg-fried"></i>
                            <p class="mb-0">Chưa có dữ liệu đơn hàng để thống kê.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table align-middle">
                                <thead>
                                    <tr>
                                        <th style="width:60px">#</th>
                                        <th>Món ăn</th>
                                        <th>Danh mục</th>
                                        <th class="text-end">Số lượng</th>
                                        <th class="text-end">Doanh thu</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        var rank = 1;
                                    }
                                    @foreach (var dish in items)
                                    {
                                        <tr>
                                            <td class="fw-bold">@rank</td>
                                            <td>@dish.DishName</td>
                                            <td><span class="badge badge-soft">@dish.CategoryName</span></td>
                                            <td class="text-end">@dish.TotalQuantity</td>
                                            <td class="text-end">@dish.TotalRevenue.ToString("N0") đ</td>
                                        </tr>
                                        rank++;
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
