@{
    var active = (ViewBag.ActiveNav as string ?? string.Empty).ToLowerInvariant();
}

<div class="card shadow-sm border-0" style="border-radius: 14px;">
    <div class="card-body p-3">
        <div class="d-flex align-items-center mb-3">
            <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 44px; height: 44px;">
                <i class="bi bi-shield-lock-fill"></i>
            </div>
            <div class="ms-2">
                <div class="fw-bold">Admin</div>
                <small class="text-muted">@ViewBag.RoleName</small>
            </div>
        </div>

        <div class="list-group list-group-flush">
            <a href="@Url.Action("Index", "Dashboard", new { area = "Admin" })"
               class="list-group-item list-group-item-action d-flex align-items-center @(active == "dashboard" ? "active" : "")">
                <i class="bi bi-grid-fill me-2"></i> Dashboard
            </a>
            <a href="@Url.Action("Index", "Categories", new { area = "Admin" })"
               class="list-group-item list-group-item-action d-flex align-items-center @(active == "categories" ? "active" : "")">
                <i class="bi bi-folder2-open me-2"></i> Quản lý danh mục
            </a>
            <a href="@Url.Action("Index", "Ingredients", new { area = "Admin" })"
               class="list-group-item list-group-item-action d-flex align-items-center @(active == "ingredients" ? "active" : "")">
                <i class="bi bi-basket3-fill me-2"></i> Nguyên liệu / thành phần
            </a>
            <a href="@Url.Action("Index", "Dishes", new { area = "Admin" })"
               class="list-group-item list-group-item-action d-flex align-items-center @(active == "dishes" ? "active" : "")">
                <i class="bi bi-egg-fried me-2"></i> Quản lý món ăn
            </a>
            <a href="@Url.Action("Index", "Tables", new { area = "Admin" })"
               class="list-group-item list-group-item-action d-flex align-items-center @(active == "tablesqr" ? "active" : "")">
                <i class="bi bi-grid-3x3-gap-fill me-2"></i> Quản lý bàn &amp; QR
            </a>
            <a href="@Url.Action("Index", "Employees", new { area = "Admin" })"
               class="list-group-item list-group-item-action d-flex align-items-center @(active == "employees" ? "active" : "")">
                <i class="bi bi-people-fill me-2"></i> Quản lý nhân viên
            </a>
            <a href="@Url.Action("Index", "Customers", new { area = "Admin" })"
               class="list-group-item list-group-item-action d-flex align-items-center @(active == "customers" ? "active" : "")">
                <i class="bi bi-person-badge-fill me-2"></i> Quản lý khách hàng
            </a>

            <div class="text-uppercase text-muted small fw-semibold px-3 pt-3 pb-1">Báo cáo</div>
            <a href="@Url.Action("Revenue", "Reports", new { area = "Admin" })"
               class="list-group-item list-group-item-action d-flex align-items-center @(active == "reports-revenue" ? "active" : "")">
                <i class="bi bi-cash-coin me-2"></i> Doanh thu
            </a>
            <a href="@Url.Action("TopDishes", "Reports", new { area = "Admin" })"
               class="list-group-item list-group-item-action d-flex align-items-center @(active == "reports-topdishes" ? "active" : "")">
                <i class="bi bi-graph-up-arrow me-2"></i> Món ăn gọi nhiều
            </a>

            <div class="text-uppercase text-muted small fw-semibold px-3 pt-3 pb-1">Tài khoản</div>
            <a href="@Url.Action("Index", "Settings", new { area = "Admin" })"
               class="list-group-item list-group-item-action d-flex align-items-center @(active == "settings" ? "active" : "")">
                <i class="bi bi-gear-fill me-2"></i> Cài đặt tài khoản
            </a>

            <form method="post" action="@Url.Action("Logout", "Account", new { area = "Staff" })">
                @Html.AntiForgeryToken()
                <button type="submit" class="list-group-item list-group-item-action d-flex align-items-center text-danger border-0 bg-transparent w-100 text-start">
                    <i class="bi bi-box-arrow-right me-2"></i> Đăng xuất
                </button>
            </form>
        </div>
    </div>
</div>
