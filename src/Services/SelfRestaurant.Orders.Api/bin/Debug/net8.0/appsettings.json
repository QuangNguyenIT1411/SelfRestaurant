{
  "ConnectionStrings": {
    "RestaurantDb": "Server=(localdb)\\MSSQLLocalDB;Database=RESTAURANT_ORDERS;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=True"
  },
  "Services": {
    "Catalog": "http://localhost:5101",
    "Billing": "http://localhost:5105",
    "TimeoutSeconds": 30
  },
  "HttpsRedirection": {
    "Enabled": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "IntegrationEvents": {
    "Enabled": true,
    "Directory": "App_Data/integration-events",
    "OutboxTrackedEvents": [
      "order.status-ready.v1"
    ],
    "Consumers": {
      "PaymentCompleted": {
        "Enabled": true,
        "PollIntervalSeconds": 2,
        "Take": 20
      }
    }
  },
  "RabbitMq": {
    "Enabled": false,
    "Host": "localhost",
    "Port": 5672,
    "Username": "guest",
    "Password": "guest",
    "VirtualHost": "/",
    "Exchange": "selfrestaurant.events",
    "RoutingKeyPrefix": "selfrestaurant"
  }
}
