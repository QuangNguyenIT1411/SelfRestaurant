{
  "ConnectionStrings": {
    "RestaurantDb": "Server=(localdb)\\MSSQLLocalDB;Database=RESTAURANT_BILLING;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=True"
  },
  "Services": {
    "Orders": "http://localhost:5102",
    "Customers": "http://localhost:5103",
    "TimeoutSeconds": 30
  },
  "HttpsRedirection": {
    "Enabled": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "IntegrationEvents": {
    "Enabled": true,
    "Directory": "App_Data/integration-events",
    "OutboxTrackedEvents": [
      "payment.completed.v1"
    ]
  },
  "RabbitMq": {
    "Enabled": false,
    "Host": "localhost",
    "Port": 5672,
    "Username": "guest",
    "Password": "guest",
    "VirtualHost": "/",
    "Exchange": "selfrestaurant.events",
    "RoutingKeyPrefix": "selfrestaurant"
  }
}
