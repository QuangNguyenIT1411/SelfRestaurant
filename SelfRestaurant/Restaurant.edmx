            <DefiningQuery>SELECT 
    [BranchRevenue].[BranchID] AS [BranchID], 
    [BranchRevenue].[BranchName] AS [BranchName], 
    [BranchRevenue].[TotalOrders] AS [TotalOrders], 
    [BranchRevenue].[TotalRevenue] AS [TotalRevenue], 
    [BranchRevenue].[OrderDate] AS [OrderDate]
    FROM [dbo].[BranchRevenue] AS [BranchRevenue]</DefiningQuery>
          </EntitySet>
          <EntitySet Name="CustomerLoyalty" EntityType="Self.CustomerLoyalty" store:Type="Views" store:Schema="dbo">
