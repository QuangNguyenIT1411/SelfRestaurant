@{
    ViewBag.Title = "Liên Hệ";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var isCustomerLoggedIn = Session["CustomerID"] != null;
    var customerName = isCustomerLoggedIn ? Session["CustomerName"]?.ToString() : "";

    var hasCurrentTable = Session["CurrentTableID"] != null;
    var currentTableID = hasCurrentTable ? (int)Session["CurrentTableID"] : 0;
    var currentBranchID = hasCurrentTable ? (int)Session["CurrentBranchID"] : 0;
    var currentBranchName = hasCurrentTable ? Session["CurrentBranchName"]?.ToString() : "";
    var currentTableNumber = hasCurrentTable ? (int)Session["CurrentTableNumber"] : 0;
}

@section css{
    <style>
        body {
            font-family: "Inter", sans-serif;
            background-color: #f8f9fa;
        }

        .navbar-brand {
            font-weight: 700;
            font-size: 1.75rem;
            color: #d9534f !important;
        }

        .nav-link {
            font-weight: 500;
        }

        .hero-section {
            background: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)), url("https://placehold.co/1920x600/444/ffffff?text=Self+Restaurant+-+Lien+He");
            background-size: cover;
            background-position: center;
            color: white;
            padding: 6rem 0;
            text-align: center;
        }

            .hero-section h1 {
                font-size: 3rem;
                font-weight: 700;
            }

            .hero-section p {
                font-size: 1.2rem;
                margin-bottom: 2rem;
            }

        .section-container {
            background-color: #ffffff;
            padding: 3rem 0;
        }

        .section-title {
            font-weight: 600;
            margin-bottom: 2rem;
            font-size: 2rem;
            text-align: center;
        }

        .footer {
            background-color: #343a40;
            color: white;
            padding: 3rem 0;
            text-align: center;
        }

            .footer p {
                margin-bottom: 0.5rem;
            }

        .social-icons a {
            color: white;
            font-size: 1.5rem;
            margin: 0 0.75rem;
            transition: color 0.2s;
        }

            .social-icons a:hover {
                color: #d9534f;
            }

        .customer-dropdown {
            color: #d9534f;
        }
    </style>
}

<nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm sticky-top">
    <div class="container">
        <a class="navbar-brand" href="@Url.Action("Index", "Home")">Self Restaurant</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto">
                <li class="nav-item">
                    <a class="nav-link" href="@Url.Action("Index", "Home")">Trang Chủ</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="@Url.Action("About", "Home")">Về Chúng Tôi</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link active" href="@Url.Action("Contact", "Home")">Liên Hệ</a>
                </li>

                @if (isCustomerLoggedIn)
                {
                    if (hasCurrentTable)
                    {
                        <li class="nav-item me-2">
                            <a class="nav-link btn btn-outline-danger px-3 text-danger"
                               href="@Url.Action("Index", "Menu", new { tableId = currentTableID, branchId = currentBranchID })">
                                <i class="fas fa-chair me-1"></i>Bàn hiện tại (@currentTableNumber)
                            </a>
                        </li>
                    }

                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle customer-dropdown" href="#" id="customerDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="fas fa-user-circle me-1"></i>@customerName
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="customerDropdown">
                            <li>
                                <a class="dropdown-item" href="@Url.Action("Dashboard", "Customer")">
                                    <i class="fas fa-th-large me-2"></i>Dashboard
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="@Url.Action("Profile", "Customer")">
                                    <i class="fas fa-user me-2"></i>Hồ Sơ Cá Nhân
                                </a>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item text-danger" href="@Url.Action("Logout", "Customer")">
                                    <i class="fas fa-sign-out-alt me-2"></i>Đăng Xuất
                                </a>
                            </li>
                        </ul>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Login", "Customer")">
                            <i class="fas fa-sign-in-alt me-1"></i>Đăng Nhập
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link btn btn-danger btn-sm ms-2 text-white" href="@Url.Action("Register", "Customer")">
                            <i class="fas fa-user-plus me-1"></i>Đăng Ký
                        </a>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>

<header class="hero-section">
    <div class="container">
        <h1>Liên hệ Self Restaurant</h1>
        <p>Chúng tôi luôn sẵn sàng lắng nghe ý kiến từ bạn.</p>
    </div>
</header>

<section class="section-container">
    <div class="container">
        <h2 class="section-title">Thông tin liên hệ</h2>
        <div class="row justify-content-center">
            <div class="col-lg-6 text-start">
                <p class="mb-3">
                    Nếu bạn có góp ý hoặc cần hỗ trợ, vui lòng liên hệ:
                </p>
                <ul>
                    <li>Email: support@selfrestaurant.local</li>
                    <li>Điện thoại: 0123 456 789</li>
                    <li>Địa chỉ: 123 Nguyễn Huệ, Quận 1, TP.HCM</li>
                </ul>
            </div>
        </div>
    </div>
</section>

<footer class="footer">
    <div class="container">
        <div class="social-icons mb-3">
            <a href="#"><i class="fab fa-facebook-f"></i></a>
            <a href="#"><i class="fab fa-instagram"></i></a>
            <a href="#"><i class="fab fa-twitter"></i></a>
        </div>
        <p>&copy; 2024 Self Restaurant. Đã đăng ký bản quyền.</p>
        <p>Một dự án của OOAD Team.</p>
    </div>
</footer>
