@model SelfRestaurant.Areas.Admin.Models.AdminDashboardViewModel
@{
    ViewBag.Title = "Admin Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section css{
    <style>
        body {
            background: radial-gradient(circle at 10% 20%, #f6f9ff 0, #eef3ff 40%, #ffffff 90%);
            color: #0f172a;
        }

        .hero-card {
            border: none;
            border-radius: 18px;
            box-shadow: 0 20px 50px rgba(15, 23, 42, 0.08);
            overflow: hidden;
        }

        .stat-card {
            border: 1px solid #e6e9f2;
            border-radius: 16px;
            transition: transform 0.15s ease, box-shadow 0.15s ease;
        }

            .stat-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 16px 40px rgba(15, 23, 42, 0.08);
            }

        .badge-soft {
            padding: 0.35rem 0.65rem;
            border-radius: 999px;
            font-weight: 600;
            font-size: 0.85rem;
        }

        .badge-soft-success {
            background: #e8fff3;
            color: #0f9d58;
        }

        .badge-soft-warning {
            background: #fff7e6;
            color: #f59e0b;
        }

        .badge-soft-info {
            background: #e7f3ff;
            color: #2563eb;
        }

        .badge-soft-danger {
            background: #fff1f1;
            color: #d93025;
        }
    </style>
}

<div class="container py-4">
    <div class="row g-3">
        <div class="col-lg-3">
            @Html.Partial("~/Areas/Admin/Views/Shared/_AdminSidebar.cshtml")
        </div>
        <div class="col-lg-9">
            <div class="hero-card bg-white p-4 mb-4">
                <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                    <div>
                        <div class="text-muted mb-1">Xin chào, @ViewBag.EmployeeName</div>
                        <h1 class="fw-bold mb-2">Tổng quan doanh thu</h1>
                        <div class="d-flex gap-3 flex-wrap text-muted small">
                            <span><i class="bi bi-building me-1"></i>Chi nhánh: @ViewBag.BranchName</span>
                            <span><i class="bi bi-shield-check me-1"></i>Vai trò: @ViewBag.RoleName</span>
                        </div>
                    </div>
                    <div class="text-end">
                        <div class="badge-soft badge-soft-info">
                            <i class="bi bi-clock me-1"></i>@DateTime.Now.ToString("dd/MM/yyyy HH:mm")
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-3 col-sm-6">
                    <div class="stat-card bg-white p-3 h-100">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <div class="text-muted small">Doanh thu hôm nay</div>
                                <div class="fs-2 fw-bold">@string.Format("{0:n0} đ", Model.TodayRevenue)</div>
                            </div>
                            <div class="text-danger fs-3">
                                <i class="bi bi-cash-stack"></i>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 col-sm-6">
                    <div class="stat-card bg-white p-3 h-100">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <div class="text-muted small">Đơn hàng hôm nay</div>
                                <div class="fs-2 fw-bold">@Model.TodayOrders</div>
                            </div>
                            <div class="text-info fs-3">
                                <i class="bi bi-receipt-cutoff"></i>
                            </div>
                        </div>
                        <div class="badge-soft @(Model.PendingOrders > 0 ? "badge-soft-danger" : "badge-soft-info") mt-2">
                            @Model.PendingOrders @(" đang chờ/đang làm")
                        </div>
                    </div>
                </div>
                <div class="col-md-3 col-sm-6">
                    <div class="stat-card bg-white p-3 h-100">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <div class="text-muted small">Tổng nhân viên</div>
                                <div class="fs-2 fw-bold">@Model.TotalEmployees</div>
                            </div>
                            <div class="text-primary fs-3">
                                <i class="bi bi-people-fill"></i>
                            </div>
                        </div>
                        <div class="badge-soft badge-soft-success mt-2">
                            @if (Model.TotalEmployees > 0)
                            {
                                var rate = (decimal)Model.ActiveEmployees / Model.TotalEmployees * 100;
                                @(string.Format("{0:n1}% đang mở", rate))
                            }
                            else
                            {
                                @("Chưa có nhân viên")
                            }
                        </div>
                    </div>
                </div>
                <div class="col-md-3 col-sm-6">
                    <div class="stat-card bg-white p-3 h-100">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <div class="text-muted small">Chi nhánh</div>
                                <div class="fs-2 fw-bold">@Model.BranchCount</div>
                            </div>
                            <div class="text-warning fs-3">
                                <i class="bi bi-geo-alt-fill"></i>
                            </div>
                        </div>
                        <div class="badge-soft badge-soft-warning mt-2">Đang mở hoạt động</div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-white border-0 d-flex align-items-center justify-content-between">
                    <div>
                        <h5 class="mb-0">Nhân viên cập nhật gần đây</h5>
                        <small class="text-muted">Top 5 nhân viên mới tạo hoặc chỉnh sửa</small>
                    </div>
                    <a href="@Url.Action("Index", "Employees")" class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-people me-1"></i>Quản lý nhân viên
                    </a>
                </div>
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Nhân viên</th>
                                <th>Vai trò</th>
                                <th>Chi nhánh</th>
                                <th>Liên hệ</th>
                                <th>Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.LatestEmployees == null || Model.LatestEmployees.Count == 0)
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-4">Chưa có dữ liệu.</td>
                                </tr>
                            }
                            else
                            {
                                foreach (var emp in Model.LatestEmployees)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@emp.Name</div>
                                            <div class="small text-muted">ID: @emp.EmployeeID</div>
                                        </td>
                                        <td>
                                            <div class="fw-semibold">@(emp.EmployeeRoles != null ? emp.EmployeeRoles.RoleName : "-")</div>
                                            <div class="small text-muted">@(emp.EmployeeRoles != null ? emp.EmployeeRoles.RoleCode : "-")</div>
                                        </td>
                                        <td>
                                            <div class="fw-semibold">@(emp.Branches != null ? emp.Branches.Name : "-")</div>
                                            <div class="small text-muted">@(emp.Branches != null ? emp.Branches.Location : "-")</div>
                                        </td>
                                        <td>
                                            <div class="small"><i class="bi bi-telephone me-1"></i>@(emp.Phone ?? "-")</div>
                                            <div class="small text-muted"><i class="bi bi-envelope me-1"></i>@(emp.Email ?? "-")</div>
                                        </td>
                                        <td>
                                            @if (emp.IsActive == true)
                                            {
                                                <span class="badge-soft badge-soft-success">
                                                    <i class="bi bi-check2-circle me-1"></i>Hoạt động
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge-soft badge-soft-danger">
                                                    <i class="bi bi-slash-circle me-1"></i>Khóa
                                                </span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
