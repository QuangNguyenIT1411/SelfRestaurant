@model SelfRestaurant.Areas.Admin.Models.RevenueReportViewModel
@using System.Collections.Generic
@{
    ViewBag.Title = "Báo cáo doanh thu";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var rows = Model?.RevenueByBranchDate ?? new List<SelfRestaurant.Areas.Admin.Models.RevenueReportRow>();
}

@section css{
    <style>
        body {
            background: radial-gradient(circle at 20% 20%, #f5f7ff 0, #eef2f9 30%, #e5ebf7 60%, #f8fbff 100%);
            color: #0f172a;
        }

        .page-title {
            font-weight: 800;
            letter-spacing: -0.5px;
            color: #0b132b;
        }

        .card-hero {
            border: none;
            border-radius: 18px;
            box-shadow: 0 15px 40px rgba(15, 23, 42, 0.08);
        }

        .badge-soft {
            background: #eef2ff;
            color: #4338ca;
        }

        .table > :not(caption) > * > * {
            padding: 14px 12px;
        }

        .table thead {
            background: #f6f8fb;
            text-transform: uppercase;
            font-size: 12px;
            letter-spacing: 0.04em;
        }

        .empty-state {
            padding: 32px 16px;
            color: #6b7280;
            text-align: center;
        }
    </style>
}

<div class="container py-4">
    <div class="row g-3">
        <div class="col-lg-3">
            @Html.Partial("~/Areas/Admin/Views/Shared/_AdminSidebar.cshtml")
        </div>
        <div class="col-lg-9">
            <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
                <div>
                    <h1 class="page-title mb-1">Báo cáo doanh thu</h1>
                    <p class="text-muted mb-0">Tổng quan doanh thu theo ngày và chi nhánh.</p>
                </div>
                <div class="card card-hero px-4 py-3">
                    <div class="text-muted text-uppercase small fw-semibold mb-1">Tổng doanh thu</div>
                    <div class="fs-2 fw-bold text-primary">@((Model?.TotalRevenue ?? 0).ToString("N0")) đ</div>
                </div>
            </div>

            <div class="card card-hero">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <div>
                            <h5 class="mb-0">Doanh thu theo chi nhánh</h5>
                            <small class="text-muted">Dữ liệu lấy từ 50 dòng gần nhất của view BranchRevenue.</small>
                        </div>
                    </div>
                    @if (!rows.Any())
                    {
                        <div class="empty-state">
                            <i class="bi bi-graph-up"></i>
                            <p class="mb-0">Chưa có dữ liệu doanh thu.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table align-middle">
                                <thead>
                                    <tr>
                                        <th>Ngày</th>
                                        <th>Chi nhánh</th>
                                        <th class="text-end">Số đơn</th>
                                        <th class="text-end">Doanh thu</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in rows)
                                    {
                                        <tr>
                                            <td>@(row.OrderDate.HasValue ? row.OrderDate.Value.ToString("dd/MM/yyyy") : "-")</td>
                                            <td>@row.BranchName</td>
                                            <td class="text-end">@row.TotalOrders</td>
                                            <td class="text-end">@row.TotalRevenue.ToString("N0") đ</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
