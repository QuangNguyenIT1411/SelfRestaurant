@model SelfRestaurant.Ingredients
@{
    ViewBag.Title = "Cập nhật nguyên liệu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="row g-3">
        <div class="col-lg-3">
            @Html.Partial("~/Areas/Admin/Views/Shared/_AdminSidebar.cshtml")
        </div>
        <div class="col-lg-9">
            <h2 class="mb-3">Cập nhật nguyên liệu</h2>

            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(m => m.IngredientID)

                <div class="card shadow-sm">
                    <div class="card-body">
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Tên nguyên liệu</label>
                                @Html.TextBoxFor(m => m.Name, new { @class = "form-control" })
                                @Html.ValidationMessageFor(m => m.Name, "", new { @class = "text-danger" })
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Đơn vị</label>
                                @Html.TextBoxFor(m => m.Unit, new { @class = "form-control", placeholder = "kg, lít, hộp..." })
                                @Html.ValidationMessageFor(m => m.Unit, "", new { @class = "text-danger" })
                            </div>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Tồn kho hiện tại</label>
                                @Html.TextBoxFor(m => m.CurrentStock, new { @class = "form-control", type = "number", step = "0.01", min = "0" })
                                @Html.ValidationMessageFor(m => m.CurrentStock, "", new { @class = "text-danger" })
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Mức cảnh báo (sắp hết)</label>
                                @Html.TextBoxFor(m => m.ReorderLevel, new { @class = "form-control", type = "number", step = "0.01", min = "0" })
                                @Html.ValidationMessageFor(m => m.ReorderLevel, "", new { @class = "text-danger" })
                            </div>
                        </div>

                        <div class="form-check mb-3">
                            @Html.CheckBoxFor(m => m.IsActive, new { @class = "form-check-input", id = "chkIsActive" })
                            <label class="form-check-label" for="chkIsActive">Đang sử dụng</label>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                                Quay lại danh sách
                            </a>
                            <button type="submit" class="btn btn-primary">
                                Lưu thay đổi
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

